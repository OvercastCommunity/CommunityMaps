<map proto="1.5.1">
<name>Pillars</name>
<variant id="ffa" world="ffa">FFA</variant>
<version>1.1.2</version>
<objective>Be the last player standing!</objective>
<gamemode>blitz</gamemode>
<include id="void-death" />
<if variant="ffa">
    <created>2026-06-09</created>
    <phase>development</phase>
</if>
<unless variant="ffa">
    <created>2025-05-28</created>
    <phase>staging</phase>
</unless>
<constants>
    <constant id="ANNOUNCER_PREFIX">`a[Announcer]:`r</constant>
</constants>
<authors>
    <if variant="ffa">
        <author uuid="64e840c8-4fb5-4659-a36b-ff93e2f6113a" /> <!-- Javg_ -->
    </if>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
</authors>
<contributors>
    <contributor uuid="e82603df-417d-4a95-bd1f-1720648be0b4" contribution="XML"/> <!-- Pablete1234 -->
    <contributor uuid="e2d2c2c6-cea9-4510-9ab2-a091b5605b30" contribution="Mental help"/> <!-- Ruediger_LP -->
    <contributor contribution="intelligence">Claude Sonnet 4</contributor> <!-- Claude -->
</contributors>
<if variant="ffa">
    <players max="84" />
</if>
<unless variant="ffa">
    <teams>
        <team id="black-team" color="black" max="4">Black</team>
        <team id="white-team" color="white" max="4">White</team>
        <team id="red-team" color="red" max="4">Red</team>
        <team id="blue-team" color="blue" max="4">Blue</team>
        <team id="green-team" color="green" max="4">Green</team>
        <team id="yellow-team" color="yellow" max="4">Yellow</team>
        <team id="purple-team" color="dark purple" max="4">Purple</team>
        <team id="aqua-team" color="dark aqua" max="4">Aqua</team>
    </teams>
</unless>
<blitz>
    <lives>2</lives>
</blitz>
<time>10m</time>
<kits>
    <kit id="default-kit">
        <effect amplifier="5" duration="5s">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <if variant="ffa">
        <spawn kit="default-kit" yaw="0" region="obs-spawn-point" />
    </if>
    <unless variant="ffa">
        <spawn kit="default-kit" team="black-team" angle="0,34,0" region="black-spawn-point"/>
        <spawn kit="default-kit" team="white-team" angle="0,34,0" region="white-spawn-point"/>
        <spawn kit="default-kit" team="red-team" angle="0,34,0" region="red-spawn-point"/>
        <spawn kit="default-kit" team="blue-team" angle="0,34,0" region="blue-spawn-point"/>
        <spawn kit="default-kit" team="green-team" angle="0,34,0" region="green-spawn-point"/>
        <spawn kit="default-kit" team="yellow-team" angle="0,34,0" region="yellow-spawn-point"/>
        <spawn kit="default-kit" team="purple-team" angle="0,34,0" region="purple-spawn-point"/>
        <spawn kit="default-kit" team="aqua-team" angle="0,34,0" region="aqua-spawn-point"/>
    </unless>
    <default yaw="0" region="obs-spawn-point"/>
</spawns>
<respawn auto="true"/>
<regions>
    <cylinder id="black-spawn-point" base="7.5,32,7.5" radius="0" height="1"/>
    <cylinder id="white-spawn-point" base="0.5,32,10.5" radius="0" height="1"/>
    <cylinder id="red-spawn-point" base="-6.5,32,7.5" radius="0" height="1"/>
    <cylinder id="blue-spawn-point" base="-9.5,32,0.5" radius="0" height="1"/>
    <cylinder id="green-spawn-point" base="-6.5,32,-6.5" radius="0" height="1"/>
    <cylinder id="yellow-spawn-point" base="0.5,32,-9.5" radius="0" height="1"/>
    <cylinder id="purple-spawn-point" base="7.5,32,-6.5" radius="0" height="1"/>
    <cylinder id="aqua-spawn-point" base="10.5,32,0.5" radius="0" height="1"/>
    <cylinder id="obs-spawn-point" base="0.5,35,0.5" radius="0" height="1"/>
</regions>
<if variant="ffa">
    <structures>
        <structure id="pillar-structure">
            <region>
                <cuboid min="2,5,2" max="-1,32,-1" />
            </region>
        </structure>
    </structures>
</if>
<variables>
    <if variant="ffa">
        <array id="pillars_x" size="150" scope="match" />
        <array id="pillars_z" size="150" scope="match" />
        <array id="pillars_angle" size="150" scope="match" />
        <array id="center" size="2" scope="match" />
        <array id="paste_coords" size="2" scope="match" />
        <variable id="rings" scope="match" />
        <variable id="ready" scope="match" />
        <variable id="current_ring" scope="match" />
        <variable id="players_left" scope="match" />
        <variable id="i" scope="match" />
        <variable id="calc" scope="match" />
        <variable id="angle" scope="match" />
        <variable id="radius" default="20" scope="match" />
        <variable id="players" scope="match" />
        <variable id="id" scope="player" default="-1" />
        <variable id="should_kill" scope="player" />
        <variable id="target" scope="player" exclusive="1" />
        <variable id="first_spawn" scope="player" />
        <variable id="needs_tp" scope="player" default="1" />
        <cuboid id="spawn_checker" min="0,24,0" max="1,26,1" />
    </if>
    <variable id="next_kit" scope="player" />
</variables>
<actions>
    <if variant="ffa">
        <!-- generate pillars -->
        <trigger scope="match" filter="match-started">
            <action>
                <set var="i" value="0" />
                <switch-scope inner="player" filter="participating">
                    <set var="id" value="i" />
                    <set var="players" value="players + 1" />
                    <set var="i" value="i + 1" />
                </switch-scope>
                <set var="rings" value="max(1, ceil(log(players / 12) / log(2) + 1))" />
                <set var="center" index="0" value="0.5" />
                <set var="center" index="1" value="0.5" />
                <set var="i" value="0" />
                <set var="current_ring" value="1" />
                <repeat times="rings">
                    <set var="players_left" value="players - i" />
                    <repeat times="12 * pow(2, current_ring - 1)" filter="not(players-i=0)">
                        <set var="angle" value="(2 * 3.14159265 * i) / min(players_left, 12 * pow(2, current_ring - 1))" />
                        <set var="paste_coords" index="0" value="(radius * cos(angle)) + center[0]" />
                        <set var="paste_coords" index="1" value="(radius * sin(angle)) + center[1]" />
                        <paste-structure 
                            x="floor(paste_coords[0] + 0.5) - 1" 
                            y="0" 
                            z="floor(paste_coords[1] + 0.5) - 1" 
                            structure="pillar-structure" 
                        />
                        <set var="pillars_x" index="i" value="floor(paste_coords[0] + 0.5) - 0.5" />
                        <set var="pillars_z" index="i" value="floor(paste_coords[1] + 0.5) - 0.5" />
                        <set var="pillars_angle" index="i" value="angle" />
                        <set var="i" value="i + 1" />
                    </repeat>
                    <set var="radius" value="radius + 16" />
                    <set var="current_ring" value="current_ring + 1" />
                </repeat>
                <set var="ready" value="1" />
            </action>
        </trigger>

        <trigger scope="player" filter="all(needs_tp=1,alive)" action="tp-to-spawn" />
        <trigger scope="player" filter="dead" action="needs_tp := 1" />

        <action id="tp-to-spawn" scope="player">
            <action filter="not(id=-1)">
                <action filter="first_spawn=1">
                    <set var="spawn_checker" index="0" value="pillars_x[id] - 0.5" />
                    <set var="spawn_checker" index="2" value="pillars_z[id] - 0.5" />
                    <set var="spawn_checker" index="3" value="pillars_x[id] + 0.5" />
                    <set var="spawn_checker" index="5" value="pillars_z[id] + 0.5" />
                    <switch-scope inner="match">
                        <fill region="spawn_checker" material="air" />
                    </switch-scope>
                </action>
                <teleport
                    x="pillars_x[id]" 
                    y="24"
                    z="pillars_z[id]" 
                    yaw="(pillars_angle[id] * (180 / 3.14159265) + 90)"
                    pitch="0" 
                />
                <set var="needs_tp" value="0" />
                <set var="first_spawn" value="1" />
            </action>
        </action>

        <!-- someone was forced -->
        <trigger scope="player">
            <filter>
                <after duration="1s" filter="all(id=-1,needs_tp=1,match-started)" />
            </filter>
            <action>
                <set var="should_kill" value="1" />
                <!-- <set var="target" value="1" />
                <switch-scope inner="match">
                    <message text="${ANNOUNCER_PREFIX} A staff member forced {player} in, and there's no pillar for them...">
                        <replacements>
                            <player id="player" var="target" />
                        </replacements>
                    </message>
                </switch-scope> -->
            </action>
        </trigger>

        <trigger scope="player" filter="all(alive,should_kill=1)">
            <action>
                <message text="`7`oFrom ${ANNOUNCER_PREFIX} You were forced into the match, so there's no pillar for you :(" />
                <kit>
                    <clear effects="true" />
                    <effect amplifier="10">instant damage</effect>
                </kit>
            </action>
        </trigger>
    </if>

    <!-- randomizer logic -->  
    <trigger action="grant-random-items" scope="player">
        <filter>
            <if variant="ffa">
                <pulse period="3s" duration="0.1s">
                    <time>5s</time>
                </pulse>
            </if>
            <unless variant="ffa">
                <pulse period="5s" duration="0.1s">
                    <time>5s</time>
                </pulse>
            </unless>
        </filter>
    </trigger>

    <action id="grant-random-items" scope="player">
        <set var="next_kit" value="floor(random() * 1000)"/>
        <!-- Blocks (0-599, 60%) -->
        <kit filter="next_kit=0..39" deduct-items="false">
            <item>stone</item>
        </kit>
        <kit filter="next_kit=40..79" deduct-items="false">
            <item>cobblestone</item>
        </kit>
        <kit filter="next_kit=80..159" deduct-items="false">
            <item amount="3">wood</item>
        </kit>
        <kit filter="next_kit=160..189" deduct-items="false">
            <item>dirt</item>
        </kit>
        <kit filter="next_kit=190..219" deduct-items="false">
            <item>sand</item>
        </kit>
        <kit filter="next_kit=220..249" deduct-items="false">
            <item>gravel</item>
        </kit>
        <kit filter="next_kit=250..279" deduct-items="false">
            <item>glass</item>
        </kit>
        <kit filter="next_kit=280..309" deduct-items="false">
            <item>wool</item>
        </kit>
        <kit filter="next_kit=310..339" deduct-items="false">
            <item>brick</item>
        </kit>
        <kit filter="next_kit=340..369" deduct-items="false">
            <item>grass</item>
        </kit>
        <kit filter="next_kit=370..389" deduct-items="false">
            <item>obsidian</item>
        </kit>
        <kit filter="next_kit=390..409" deduct-items="false">
            <item>iron_block</item>
        </kit>
        <kit filter="next_kit=410..424" deduct-items="false">
            <item>gold_block</item>
        </kit>
        <kit filter="next_kit=425..429" deduct-items="false">
            <item>diamond_block</item>
        </kit>
        <kit filter="next_kit=430..449" deduct-items="false">
            <item>bookshelf</item>
        </kit>
        <kit filter="next_kit=450..459" deduct-items="false">
            <item>chest</item>
        </kit>
        <kit filter="next_kit=460..474" deduct-items="false">
            <item>sapling</item>
        </kit>
        <kit filter="next_kit=475..489" deduct-items="false">
            <item>iron_ore</item>
        </kit>
        <kit filter="next_kit=490..499" deduct-items="false">
            <item amount="2">coal_ore</item>
        </kit>
        <kit filter="next_kit=500..509" deduct-items="false">
            <item>gold_ore</item>
        </kit>
        <kit filter="next_kit=510..514" deduct-items="false">
            <item amount="2">diamond_ore</item>
        </kit>
        <kit filter="next_kit=515..529" deduct-items="false">
            <item>pumpkin</item>
        </kit>
        <kit filter="next_kit=530..549" deduct-items="false">
            <item>snow_block</item>
        </kit>
        <kit filter="next_kit=550..559" deduct-items="false">
            <item amount="2">lapis_ore</item>
        </kit>
        <kit filter="next_kit=560..599" deduct-items="false">
            <item>netherrack</item>
        </kit>
        <!-- Trash Items (600-799, 20%) -->
        <kit filter="next_kit=600..619" deduct-items="false">
            <item>rotten_flesh</item>
        </kit>
        <kit filter="next_kit=620..639" deduct-items="false">
            <item>poisonous_potato</item>
        </kit>
        <kit filter="next_kit=640..659" deduct-items="false">
            <item>dead_bush</item>
        </kit>
        <kit filter="next_kit=660..679" deduct-items="false">
            <item>spider_eye</item>
        </kit>
        <kit filter="next_kit=680..699" deduct-items="false">
            <item>bone</item>
        </kit>
        <kit filter="next_kit=700..739" deduct-items="false">
            <item>string</item>
        </kit>
        <kit filter="next_kit=720..739" deduct-items="false">
            <item>feather</item>
        </kit>
        <kit filter="next_kit=740..759" deduct-items="false">
            <item>clay_ball</item>
        </kit>
        <kit filter="next_kit=760..779" deduct-items="false">
            <item>snow_ball</item>
        </kit>
        <kit filter="next_kit=780..799" deduct-items="false">
            <item>sugar_cane</item>
        </kit>
        <!-- Useful Items (800-949, 15%) -->
        <kit filter="next_kit=800..814" deduct-items="false">
            <item>diamond</item>
        </kit>
        <kit filter="next_kit=815..829" deduct-items="false">
            <item>iron_ingot</item>
        </kit>
        <kit filter="next_kit=830..844" deduct-items="false">
            <item>gold_ingot</item>
        </kit>
        <kit filter="next_kit=845..859" deduct-items="false">
            <item>redstone</item>
        </kit>
        <kit filter="next_kit=860..874" deduct-items="false">
            <item>coal</item>
        </kit>
        <kit filter="next_kit=875..889" deduct-items="false">
            <item>bread</item>
        </kit>
        <kit filter="next_kit=890..904" deduct-items="false">
            <item>cooked_beef</item>
        </kit>
        <kit filter="next_kit=905..919" deduct-items="false">
            <item>water_bucket</item>
        </kit>
        <kit filter="next_kit=920..934" deduct-items="false">
            <item>torch</item>
        </kit>
        <kit filter="next_kit=935..944" deduct-items="false">
            <item>ender_pearl</item>
        </kit>
        <kit filter="next_kit=945..949" deduct-items="false">
            <item>lava_bucket</item>
        </kit>
        <!-- Weapons & Armor (950-997, 4.9%) -->
        <kit filter="next_kit=950..952" deduct-items="false">
            <item>diamond_sword</item>
        </kit>
        <kit filter="next_kit=953..957" deduct-items="false">
            <item>iron_sword</item>
        </kit>
        <kit filter="next_kit=958..962" deduct-items="false">
            <item>bow</item>
        </kit>
        <kit filter="next_kit=963..972" deduct-items="false">
            <item amount="16">arrow</item>
        </kit>
        <kit filter="next_kit=973..975" deduct-items="false">
            <item>diamond_helmet</item>
        </kit>
        <kit filter="next_kit=976..978" deduct-items="false">
            <item>diamond_chestplate</item>
        </kit>
        <kit filter="next_kit=979..985" deduct-items="false">
            <item>iron_helmet</item>
        </kit>
        <kit filter="next_kit=986..992" deduct-items="false">
            <item>iron_chestplate</item>
        </kit>
        <kit filter="next_kit=993..997" deduct-items="false">
            <item>leather_boots</item>
        </kit>
        <!-- Ultra Rare Items (998-999, 0.1%) -->
        <kit filter="next_kit=998" deduct-items="false">
            <item>nether_star</item>
        </kit>
        <kit filter="next_kit=999" deduct-items="false">
            <item>bedrock</item>
        </kit>
    </action>
</actions>
<if variant="ffa">
    <damage>
        <deny>
            <variable var="ready">0</variable>
        </deny>
    </damage>
</if>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
