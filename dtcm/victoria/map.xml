<map proto="1.5.0">
<name>Victoria</name>
<version>1.0.2</version>
<objective>Destroy the enemy team's obsidian monuments!</objective>
<created>2026-01-01</created>
<include id="gapple-kill-reward"/>
<phase>staging</phase>
<authors>
    <author uuid="bf331953-4f92-43ee-8abc-7544b8234936"/> <!-- ViceWatercolour -->
</authors>
<teams>
    <team id="gray-team" color="dark gray" max="14">Gray</team>
    <team id="green-team" color="green" max="14">Green</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="iron sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="28" material="arrow" amount="64"/>
        <item slot="2" unbreakable="true" material="diamond pickaxe"/>
        <item slot="3" unbreakable="true" material="iron axe"/>
        <item slot="4" amount="64" damage="1" material="wood"/>
        <item slot="5" amount="64" damage="1" material="wood"/>
        <item slot="6" amount="32" material="glass"/>
        <item slot="8" material="golden apple"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" team-color="true" material="leather leggings"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
        <effect duration="3s" amplifier="255">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <default yaw="180">
        <region>
            <point>-55.5,20,23.5</point>
        </region>
    </default>
    <spawn team="gray-team" kit="spawn-kit">
        <regions>
            <point yaw="-35">-3.5,11,-6.5</point>
            <point yaw="-135">-5.5,11,53.5</point>
        </regions>
    </spawn>
    <spawn team="green-team" kit="spawn-kit">
        <regions>
            <point yaw="135">-55.5,20,23.5</point>
            <point yaw="35">-105.5,11,-7.5</point>
        </regions>
    </spawn>
</spawns>
<regions>
    <union id="spawns">
        <circle id="gray-spawn-1" center="-3,-6" radius="6"/>
        <circle id="gray-spawn-2" center="-5,53" radius="6"/>
        <circle id="green-spawn-1" center="-55,23" radius="6"/>
        <circle id="green-spawn-2" center="-105,-7" radius="6"/>
    </union>
    <apply block="never" region="spawns" message="You may not modify the spawn area!"/>
    <apply enter="green-team" region="green-spawn-1" message="You may not enter the enemy's spawn!"/>
    <apply enter="green-team" region="green-spawn-2" message="You may not enter the enemy's spawn!"/>
    <apply enter="gray-team" region="gray-spawn-1" message="You may not enter the enemy's spawn!"/>
    <apply enter="gray-team" region="gray-spawn-2" message="You may not enter the enemy's spawn!"/>
    <negative id="playable-inverse">
        <cuboid id="playable" min="48,0,-19" max="-158,24,65"/>
    </negative>
    <apply block="never" region="playable-inverse" message="You may not build outside the map!"/>
    <apply block="deny-lava" message="You may not use lava!"/>
    <apply use="deny-beacon"/>
</regions>
<filters>
    <not id="deny-lava">
        <any>
            <material>lava</material>
            <material>stationary lava</material>
        </any>
    </not>
    <deny id="deny-beacon">
        <material>beacon</material>
    </deny>
</filters>
<destroyables materials="obsidian" show-progress="true" required="true" mode-changes="true">
    <destroyable owner="gray-team" name="Left">
        <region>
            <block>20,21,-7</block>
        </region>
    </destroyable>
    <destroyable owner="gray-team" name="Right">
        <region>
            <block>20,21,53</block>
        </region>
    </destroyable>
    <destroyable owner="green-team" name="Left">
        <region>
            <block>-130,21,53</block>
        </region>
    </destroyable>
    <destroyable owner="green-team" name="Right">
        <region>
            <block>-130,21,-7</block>
        </region>
    </destroyable>
</destroyables>
<modes>
    <mode after="30m" material="beacon" name="`bBEACON MONUMENT MODE"/>
</modes>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>diamond pickaxe</tool>
    <tool>iron axe</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>obsidian</item>
    <item>beacon</item>
    <item>red mushroom</item>
    <item>sapling</item>
    <item>glowstone dust</item>
    <item>torch</item>
    <item>apple</item>
</itemremove>
<itemkeep>
    <item>golden apple</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="16" material="arrow"/>
        <item amount="16" damage="3" material="wood"/>
    </kill-reward>
</kill-rewards>
<maxbuildheight>24</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
<respawn auto="true" delay="3s"/>
</map>
