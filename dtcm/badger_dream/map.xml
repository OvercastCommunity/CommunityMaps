<map proto="1.5.0">
<name>Badger Dream</name>
<version>1.0.1</version>
<objective>Destroy the enemy team's obsidian monument!</objective>
<created>2026-04-17</created>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="644521d7-9437-47c1-b1d2-698eb757df3d"/> <!-- minuyo -->
</authors>
<teams>
    <team id="red-team" color="dark red" max="24">Red</team>
    <team id="blue-team" color="blue" max="24">Blue</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="iron sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="28" material="arrow" amount="64"/>
        <item slot="2" unbreakable="true" material="diamond pickaxe"/>
        <item slot="29" unbreakable="true" material="shears"/>
        <item slot="3" unbreakable="true" material="iron axe"/>
        <item slot="30" unbreakable="true" material="iron spade"/>
        <item slot="4" amount="64" damage="5" material="wood"/>
        <item slot="5" amount="64" damage="5" material="wood"/>
        <item slot="6" amount="32" material="glass"/>
        <item slot="8" material="golden apple"/>
        <effect duration="3s" amplifier="255">damage resistance</effect>
    </kit>
    <kit id="red-kit" parent="spawn-kit">
        <helmet unbreakable="true" color="993333" material="leather helmet"/>
        <chestplate unbreakable="true" color="993333" material="leather chestplate"/>
        <leggings unbreakable="true" color="993333" material="leather leggings"/>
        <boots unbreakable="true" color="993333" material="leather boots"/>
    </kit>
    <kit id="blue-kit" parent="spawn-kit">
        <helmet unbreakable="true" color="3F3399" material="leather helmet"/>
        <chestplate unbreakable="true" color="3F3399" material="leather chestplate"/>
        <leggings unbreakable="true" color="3F3399" material="leather leggings"/>
        <boots unbreakable="true" color="3F3399" material="leather boots"/>
    </kit>
</kits>
<spawns>
    <default yaw="-180">
        <region>
            <point>0.5,110,65.5</point>
        </region>
    </default>
    <spawn team="red-team" kit="red-kit" yaw="35">
        <region>
            <point>-86.5,30,-18.5</point>
        </region>
    </spawn>
    <spawn team="blue-team" kit="blue-kit" yaw="-145">
        <region>
            <point>87.5,30,19.5</point>
        </region>
    </spawn>
</spawns>
<filters>
    <material id="only-iron">iron block</material>
</filters>
<regions>
    <union id="spawns">
        <cuboid id="red-spawn" min="-79,26,-11" max="-94,oo,-26" />
        <cuboid id="blue-spawn" min="80,26,12" max="95,oo,27" />
    </union>
    <union id="iron">
        <cuboid id="red-iron" min="-87,31,28" max="-98,34,22"/>
        <cuboid id="blue-iron" min="88,31,-27" max="99,34,-21"/>
    </union>
    <apply block="never" region="spawns" message="You may not modify the spawn area!"/>
    <apply enter="red-team" region="red-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="blue-team" region="blue-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply block="deny(void)" message="You may not modify the void area!"/>
</regions>
<destroyables name="Monument" materials="obsidian" required="true" mode-changes="true">
    <destroyable owner="red-team">
        <region>
            <cuboid min="-57,30,11" max="-56,27,12"/>
            
        </region>
    </destroyable>
    <destroyable owner="blue-team">
        <region>
            <cuboid min="58,27,-10" max="57,30,-11"/>
        </region>
    </destroyable>
</destroyables>
<modes>
    <mode after="30m" material="beacon" name="`bBEACON MONUMENT MODE"/>
</modes>
<renewables>
    <renewable region="iron" renew-filter="only-iron"/>
</renewables>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>diamond pickaxe</tool>
    <tool>shears</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>obsidian</item>
    <item>beacon</item>
    <item>flint</item>
</itemremove>
<itemkeep>
    <item>arrow</item>
    <item>wood</item>
    <item>glass</item>
    <item>golden apple</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="16" material="arrow"/>
        <item amount="16" damage="5" material="wood"/>
    </kill-reward>
</kill-rewards>
<maxbuildheight>44</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
