<map proto="1.5.0">
<name>Ruby Planet</name>
<version>1.0.1</version>
<objective>Destroy the enemy team's two end stone monuments!</objective>
<created>2026-02-25</created>
<include id="gapple-kill-reward"/>
<include id="lava-buckets"/>
<authors>
    <author uuid="644521d7-9437-47c1-b1d2-698eb757df3d"/> <!-- minuyo -->
</authors>
<contributors>
    <contributor uuid="63ddf58a-ba2c-4d39-8481-6358bb46c63a" contribution="xml"/> <!-- samschaap -->
</contributors>
<teams>
    <team id="magenta-team" color="light purple" max="20">Magenta</team>
    <team id="orange-team" color="gold" max="20">Orange</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" enchantments="sharpness:2;unbreaking" material="gold sword"/>
        <item slot="1" unbreakable="true" enchantments="infinity;unbreaking" material="bow"/>
        <item slot="28" material="arrow" amount="1"/>
        <item slot="2" unbreakable="true" enchantments="efficiency;unbreaking" material="iron pickaxe"/>
        <item slot="3" unbreakable="true" enchantments="unbreaking" material="gold axe"/>
        <item slot="30" unbreakable="true" enchantments="unbreaking" material="gold spade"/>
        <item slot="4" amount="64" damage="4" material="wood"/>
        <item slot="5" amount="64" damage="4" material="wood"/>
        <item slot="6" amount="32" material="glass"/>
        <item slot="7" material="bucket"/>
        <item slot="8" material="golden apple"/>
        <item slot="35" amount="8" material="torch"/>
        <helmet unbreakable="true" enchantments="unbreaking" material="glass"/>
        <chestplate unbreakable="true" enchantments="unbreaking" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" enchantments="unbreaking" material="iron leggings"/>
        <boots unbreakable="true" enchantments="unbreaking" team-color="true" material="leather boots"/>
        <effect duration="3s" amplifier="255">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <default yaw="90">
        <region>
            <point>0,76,0</point>
        </region>
    </default>
    <spawn team="magenta-team" kit="spawn-kit" yaw="0">
        <region>
            <point>-47,28,-62</point>
        </region>
    </spawn>
    <spawn team="orange-team" kit="spawn-kit" yaw="180">
        <region>
            <point>47,28,62</point>
        </region>
    </spawn>
</spawns>
<filters>
    <material id="only-iron">iron block</material>
</filters>
<regions>
    <negative id="void-area">
        <rectangle id="bridgeable-area" min="57,-68" max="-57,68"/>
    </negative>
    <union id="spawns">
        <cuboid id="magenta-spawn" min="-51,22,-53" max="-43,35,-68"/>
        <cuboid id="orange-spawn" min="51,22,53" max="43,35,68"/>
    </union>
    <union id="iron">
        <cuboid id="magenta-iron" min="-40,23,-15" max="-55,28,-22"/>
        <cuboid id="orange-iron" min="40,23,15" max="55,28,22"/>
    </union>
    <cuboid id="magenta-front-monument" min="-14,18,-31" max="-7,25,-38"/>
    <cuboid id="orange-front-monument" min="14,18,31" max="7,25,38"/>
    <cuboid id="magenta-back-monument" min="25,18,-38" max="32,25,-45"/>
    <cuboid id="orange-back-monument" min="-25,18,38" max="-32,25,45"/>
    <apply block="never" region="spawns" message="You may not modify the spawn area!"/>
    <apply enter="magenta-team" region="magenta-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="orange-team" region="orange-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply block="deny(void)" region="void-area" message="You may not modify the void area!"/>
</regions>
<destroyables materials="ender stone" required="true" show-progress="true">
    <destroyable name="Front Monument" owner="magenta-team" region="magenta-front-monument"/>
    <destroyable name="Front Monument" owner="orange-team" region="orange-front-monument"/>
    <destroyable name="Back Monument" owner="magenta-team" region="magenta-back-monument"/>
    <destroyable name="Back Monument" owner="orange-team" region="orange-back-monument"/>
</destroyables>
<renewables>
    <renewable region="iron" renew-filter="only-iron"/>
</renewables>
<toolrepair>
    <tool>gold sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>gold axe</tool>
    <tool>gold spade</tool>
    <tool>bucket</tool>
</toolrepair>
<itemremove>
    <item>leather chestplate</item>
    <item>iron leggings</item>
    <item>leather boots</item>
    <item>ender stone</item>
    <item>clay ball</item>
    <item>dirt</item>
    <item>obsidian</item>
    <item>coal block</item>
    <item>flint</item>
</itemremove>
<itemkeep>
    <item>wood</item>
    <item>glass</item>
    <item>torch</item>
    <item>golden apple</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="16" damage="4" material="wood"/>
    </kill-reward>
    <kill-reward>
        <filter>
            <kill-streak count="3" repeat="true"/>
        </filter>
        <item amount="1" material="tnt"/>
    </kill-reward>
</kill-rewards>
<item-mods>
    <rule>
        <match>
            <item>iron helmet</item>
            <item>iron chestplate</item>
            <item>iron leggings</item>
            <item>iron boots</item>
        </match>
        <modify>
            <enchantment>unbreaking</enchantment>
        </modify>
    </rule>
</item-mods>
<broadcasts>
    <tip after="10s" every="3m">`6After `e3`6 kills, you will receive 1 `bTNT`6!</tip>
</broadcasts>
<maxbuildheight>35</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
