<map proto="1.5.0">
<name>Cherry City</name>
<version>1.0.0</version>
<objective>Capture the enemies flag 3 times!</objective>
<created>2026-01-17</created>
<include id="gapple-kill-reward"/>
<gamemode>ctf</gamemode>
<authors>
    <author uuid="644521d7-9437-47c1-b1d2-698eb757df3d"/>   <!-- Minuyo -->
    <author uuid="1af9f952-e33e-42a5-8e1e-296757747fdc"/>   <!-- Alphaboy98yt -->
</authors>
<contributors>
    <contributor uuid="d5a64b26-15ea-46c4-8319-f9c83e82a1fa" contribution="XML"/>   <!-- Eliminate -->
</contributors>
<teams>
    <team id="red-team" color="dark red" max="20">Red</team>
    <team id="blue-team" color="blue" max="20">Blue</team>
</teams>
<spawns>
    <default>
        <region yaw="0">
            <point>20.5,106,55.5</point>
        </region>
    </default>
    <spawn team="red-team" kit="spawn-kit">
        <region yaw="90">
            <point>113.5,25,43.5</point>
        </region>
    </spawn>
    <spawn team="blue-team" kit="spawn-kit">
        <region yaw="-90">
            <point>-72.5,25,67.5</point>
        </region>
    </spawn>
</spawns>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true"/>
        <item slot="2" amount="32" material="arrow"/>
        <item slot="3" material="golden apple"/>
        <helmet material="leather helmet" team-color="true" unbreakable="true" locked="true"/>
        <chestplate material="leather chestplate" team-color="true" unbreakable="true" locked="true"/>
        <leggings material="chainmail leggings" unbreakable="true" locked="true"/>
        <boots material="leather boots" team-color="true" unbreakable="true" locked="true"/>
        <game-mode>adventure</game-mode>
    </kit>
</kits>
<regions>
    <union id="spawns">
        <cuboid id="red-spawn" min="118,0,26" max="95,60,60"/>
        <cuboid id="blue-spawn" min="-77,0,51" max="-54,60,85"/>
    </union>
    <union id="nets">
        <cuboid id="red-net" min="81,24,73" max="88,30,80"/>
        <cuboid id="blue-net" min="-47,24,31" max="-40,30,38"/>
    </union>
    <apply block="never" use="blocks"/>
    <apply region="red-spawn" enter="all(red-team,not(carrying))"/>
    <apply region="blue-spawn" enter="all(blue-team,not(carrying))"/>
    <apply region="red-spawn" enter="red-team" message="You may not enter the opposing team's spawn!"/>
    <apply region="blue-spawn" enter="blue-team" message="You may not enter the opposing team's spawn!"/>
</regions>
<filters>
    <any id="carrying">
        <carrying-flag>red-flag</carrying-flag>
        <carrying-flag>blue-flag</carrying-flag>
    </any>
    <any id="blocks">
        <material>wooden_door</material>
        <material>spruce_door</material>
        <material>birch_door</material>
        <material>jungle_door</material>
        <material>acacia_door</material>
        <material>dark_oak_door</material>
    </any>
</filters>
<flags>
    <flag id="red-flag" name="Red Flag" owner="red-team">
        <post pickup-filter="blue-team">84,26,76</post>
    </flag>
    <flag id="blue-flag" name="Blue Flag" owner="blue-team">
        <post pickup-filter="red-team">-44,26,34</post>
    </flag>
    <flags points="1">
        <net region="red-net" flag="blue-flag" rescue="red-flag"/>
        <net region="blue-net" flag="red-flag" rescue="blue-flag"/>
    </flags>
</flags>
<score>
    <limit>3</limit>
</score>
<kill-reward>
    <item amount="16" material="arrow"/>
</kill-reward>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
</itemremove>
<itemkeep>
    <item>arrow</item>
    <item>golden apple</item>
</itemkeep>
<hunger>
    <depletion>off</depletion>
</hunger>
<damage>
    <deny>
        <cause>fall</cause>
    </deny>
</damage>
</map>
