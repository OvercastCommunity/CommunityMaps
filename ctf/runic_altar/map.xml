<map proto="1.5.0">
<name>Runic Altar</name>
<version>1.0.1</version>
<created>2026-03-29</created>
<include id="void-death"/>
<include id="gapple-kill-reward"/>
<if min-server-version="1.21.11">
    <variant world="modern" id="default"/>
    <variant world="modern" id="ctf">CTF</variant>
</if>
<unless min-server-version="1.21.11">
    <variant world="legacy" id="default"/>
    <variant world="legacy" id="ctf">CTF</variant>
</unless>
<if variant="default">
    <objective>Have the most flags captured in your altar after 7 minutes!</objective>
</if>
<if variant="ctf">
    <objective>Capture the most flags!</objective>  
</if>
<authors>
    <author uuid="f690a591-348b-482e-a18d-7779d0c0a28c"/> <!-- mitchiii -->
</authors>
<teams>
    <team id="blue-team" color="blue" max="10">Blue</team>
    <team id="red-team" color="dark red" max="10">Red</team>
</teams>
<spawns>
    <spawn team="blue-team" kit="main-kit" angle="46.5,5,-2.5">
        <regions>
            <region id="blue-north-spawn"/>
            <region id="blue-south-spawn"/>
        </regions>
    </spawn>
    <spawn team="red-team" kit="main-kit" angle="-45.5,5,-2.5">
        <regions>
            <region id="red-north-spawn"/>
            <region id="red-south-spawn"/>
        </regions>
    </spawn>
    <default>
        <regions>
            <point yaw="90">67.5,21,-2.5</point>
            <point yaw="-90">-66.5,21,-2.5</point>
        </regions>
    </default>
</spawns>
<kits>
    <kit id="main-kit">
        <clear/>
        <item slot="0" material="stone sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true"/>
        <item slot="2" material="stone pickaxe" unbreakable="true"/>
        <item slot="3" material="stone axe" unbreakable="true">
            <enchantment level="2">efficiency</enchantment>
        </item>
        <item slot="4" material="wood" amount="64" damage="2"/>
        <item slot="5" material="stained glass" amount="32" team-color="true"/>
        <item slot="8" material="golden apple"/>
        <item slot="28" material="arrow" amount="24"/>
        <item slot="30" material="stone spade" unbreakable="true">
            <enchantment level="2">efficiency</enchantment>
        </item>
        <helmet material="leather helmet" unbreakable="true" team-color="true"/>
        <chestplate material="chainmail chestplate" unbreakable="true"/>
        <leggings material="leather leggings" unbreakable="true" team-color="true"/>
        <boots unbreakable="true" material="iron boots"/>
    </kit>
    <kit id="gold-kit" deduct-items="false">
        <item material="gold ingot" amount="9"/>
    </kit>
</kits>
<kill-rewards>
    <kill-reward>
        <item material="arrow" amount="8"/>
        <item material="wood" amount="16" damage="2"/>
        <item material="stained glass" amount="8" team-color="true"/>
    </kill-reward>
    <kill-reward>
        <filter>
            <kill-streak count="3" repeat="true"/>
        </filter>
        <item material="tnt"/>
    </kill-reward>
</kill-rewards>
<regions>
    <sphere id="blue-net" origin="60.5,9,-2.5" radius="5"/>
    <sphere id="red-net" origin="-59.5,9,-2.5" radius="5"/>
    <cuboid id="cyan-flag-box" min="-1,-5,-15" size="3,15,3"/>
    <translate id="yellow-flag-box" region="cyan-flag-box" offset="0,3,11"/>
    <translate id="magenta-flag-box" region="yellow-flag-box" offset="0,-3,11"/>
    <cuboid id="cyan-flag-indicator" min="0,17,-15" size="1,7,3"/>
    <translate id="yellow-flag-indicator" region="cyan-flag-indicator" offset="0,0,11"/>
    <translate id="magenta-flag-indicator" region="yellow-flag-indicator" offset="0,0,11"/>
    <sphere id="cyan-flag-alert" origin="0.5,6,-13.5" radius="4.5"/>
    <translate id="yellow-flag-alert" region="cyan-flag-alert" offset="0,3,11"/>
    <translate id="magenta-flag-alert" region="yellow-flag-alert" offset="0,-3,11"/>
    <union id="flag-altars">
        <cuboid id="blue-flag-altar" min="58,0,-8" size="5,9,11"/>
        <cuboid id="blue-flag-altar-top" min="59,8,-6" size="3,3,7"/>
        <cuboid id="red-flag-altar" min="-62,0,-8" size="5,9,11"/>
        <cuboid id="red-flag-altar-top" min="-61,8,-6" size="3,3,7"/>
    </union>
    <union id="gold-deposits">
        <cuboid min="49,1,-36" size="5,5,5"/>
        <cuboid min="49,3,26" size="5,5,5"/>
        <cuboid min="-53,1,26" size="5,5,5"/>
        <cuboid min="-53,3,26" size="5,5,5"/>
    </union>
    <block id="blue-north-spawn" location="46,6,-56"/>
    <block id="blue-south-spawn" location="46,6,50"/>
    <block id="red-north-spawn" location="-45,6,-56"/>
    <block id="red-south-spawn" location="-45,6,50"/>
    <union id="team-spawn-protection">
        <union id="blue-spawn-protection">
            <sphere id="blue-north-spawn-prot" origin="46.5,6,50.5" radius="8"/>
            <sphere id="blue-south-spawn-prot" origin="46.5,6,-55.5" radius="8"/>
        </union>
        <union id="red-spawn-protection">
            <sphere id="red-north-spawn-prot" origin="-45.5,6,50.5" radius="8"/>
            <sphere id="red-south-spawn-prot" origin="-45.5,6,-55.5" radius="8"/>
        </union>
    </union>
    <cuboid id="blue-north-portal" min="45,6,-58" size="3,8,1"/>
    <cuboid id="blue-south-portal" min="45,6,52" size="3,8,1"/>
    <cuboid id="red-north-portal" min="-47,6,-58" size="3,8,1"/>
    <cuboid id="red-south-portal" min="-47,6,52" size="3,8,1"/>
    <apply region="blue-spawn-protection" enter="blue-team" message="You may not enter the enemy spawn!"/>
    <apply region="red-spawn-protection" enter="red-team" message="You may not enter the enemy spawn!"/>
    <apply region="team-spawn-protection" block="never" message="You may not interact with that material here"/>
    <apply region="flag-altars" block-break="never" block-place="tnt" message="You may not interact with that material here"/>
    <apply region="cyan-flag-box" block="all(cyan_flag_release=10, not(base-layer))" message="You may not interact with that material here"/>
    <apply region="yellow-flag-box" block="all(yellow_flag_release=10, not(base-layer))" message="You may not interact with that material here"/>
    <apply region="magenta-flag-box" block="all(magenta_flag_release=10, not(base-layer))" message="You may not interact with that material here"/>
    <apply region="everywhere" block="not(unbreakable-blocks)" message="You may not interact with that material here"/>
</regions>
<maxbuildheight place="tnt">13</maxbuildheight>
<portals>
    <portal region="blue-north-portal" destination="blue-south-spawn" yaw="@180" filter="blue-team"/>
    <portal region="blue-south-portal" destination="blue-north-spawn" yaw="@0" filter="blue-team"/>
    <portal region="red-north-portal" destination="red-south-spawn" yaw="@180" filter="red-team"/>
    <portal region="red-south-portal" destination="red-north-spawn" yaw="@0" filter="red-team"/>
</portals>
<filters>
    <cause id="player">player</cause>
    <material id="tnt">tnt</material>
    <material id="gold-block">gold block</material>
    <material id="stained-clay">stained clay</material>
    <any id="stained-glass">
        <material>stained glass</material>
        <material>barrier</material>
    </any>
    <any id="unbreakable-blocks">
        <all>
            <below id="base-layer" y="1"/>
            <material>stone:0</material>
        </all>
        <material>portal</material>
        <material>obsidian</material>
        <material>nether brick</material>
        <material>step:6</material>
        <material>nether brick stairs</material>
        <material>nether fence</material>
        <if min-server-version="1.12.11">
            <material>deepslate</material>
            <material>cobbled deepslate</material>
            <material>cobbled deepslate slab</material>
            <material>cobbled deepslate stairs</material>
            <material>cobbled deepslate wall</material>
            <material>warped hyphae</material>
        </if>
    </any>
</filters>
<variables scope="match" default="0">
    <score id="score"/>
    <with-team id="blue_score" var="score" team="blue-team"/>
    <with-team id="red_score" var="score" team="red-team"/>
    <variable id="cyan_flag_release"/>
    <variable id="magenta_flag_release"/>
    <variable id="yellow_flag_release"/>
    <variable id="t"/>
    <array id="flag_last_owner" scope="match" size="5"/>
    <!--
      0: blue flag
      1: red flag
      2: cyan flag
      3: yellow flag
      4: magenta flag
    -->
</variables>
<if variant="default">
    <broadcasts>
        <tip after="0m05s" every="1m" count="3">Your team gains points for every flag you have captured at your altar flag post!</tip>
        <tip after="4m05s" every="1m" count="3">Steal flags from the enemy team's altar flag post to earn more points for your team!</tip>
    </broadcasts>
    <score/>
    <time result="score">7m</time>
    <flags shared="true" carry-message="Return the flag to your team's altar!" deny-message="Return the flag to your team's altar!">
        <flag id="blue-flag" name="Blue Flag" color="blue" post="blue-post-blue-flag"/>
        <flag id="red-flag" name="Red Flag" color="red" post="red-post-red-flag"/>
        <flag id="cyan-flag" name="Cyan Flag" color="cyan" post="cyan-init-post" scoreboard-filter="cyan_flag_release=9.."/>
        <flag id="yellow-flag" name="Yellow Flag" color="yellow" post="yellow-init-post" scoreboard-filter="yellow_flag_release=9.."/>
        <flag id="magenta-flag" name="Magenta Flag" color="magenta" post="magenta-init-post" scoreboard-filter="magenta_flag_release=9.."/>
        <post id="cyan-init-post" recover-time="12s" yaw="0">0,6,-14</post>
        <post id="yellow-init-post" recover-time="12s" yaw="180">0,9,-3</post>
        <post id="magenta-init-post" recover-time="12s" yaw="180">0,6,8</post>
        <!-- blue specific posts and nets -->
        <post id="blue-post-blue-flag" owner="blue-team" recover-time="7s" respawn-time="0.1s" pickup-filter="deny-blue-own-pickup" yaw="90">60,9,-3</post>
        <post id="blue-post-red-flag" owner="blue-team" recover-time="7s" respawn-time="0.1s" pickup-filter="red-team" yaw="90">60,9,-4</post>
        <post id="blue-post-cyan-flag" owner="blue-team" recover-time="7s" respawn-time="0.1s" pickup-filter="red-team" yaw="90">60,9,-5</post>
        <post id="blue-post-yellow-flag" owner="blue-team" recover-time="7s" respawn-time="0.1s" pickup-filter="red-team" yaw="90">60,9,-2</post>
        <post id="blue-post-magenta-flag" owner="blue-team" recover-time="7s" respawn-time="0.1s" pickup-filter="red-team" yaw="90">60,9,-1</post>
        <net id="blue-net-blue-flag" region="blue-net" post="blue-post-blue-flag" flag="blue-flag" capture-filter="blue-team" respawn-filter="always" location="60.5,9,-2.5"/>
        <net id="blue-net-red-flag" region="blue-net" post="blue-post-red-flag" flag="red-flag" capture-filter="blue-team" respawn-filter="always" location="60.5,9,-2.5"/>
        <net id="blue-net-cyan-flag" region="blue-net" post="blue-post-cyan-flag" flag="cyan-flag" capture-filter="blue-team" respawn-filter="always" location="60.5,9,-2.5"/>
        <net id="blue-net-yellow-flag" region="blue-net" post="blue-post-yellow-flag" flag="yellow-flag" capture-filter="blue-team" respawn-filter="always" location="60.5,9,-2.5"/>
        <net id="blue-net-magenta-flag" region="blue-net" post="blue-post-magenta-flag" flag="magenta-flag" capture-filter="blue-team" respawn-filter="always" location="60.5,9,-2.5"/>
        <!-- red specific posts and nets -->
        <post id="red-post-blue-flag" owner="red-team" recover-time="7s" respawn-time="0.1s" pickup-filter="blue-team" yaw="-90">-60,9,-2</post>
        <post id="red-post-red-flag" owner="red-team" recover-time="7s" respawn-time="0.1s" pickup-filter="deny-red-own-pickup" yaw="-90">-60,9,-3</post>
        <post id="red-post-cyan-flag" owner="red-team" recover-time="7s" respawn-time="0.1s" pickup-filter="blue-team" yaw="-90">-60,9,-5</post>
        <post id="red-post-yellow-flag" owner="red-team" recover-time="7s" respawn-time="0.1s" pickup-filter="blue-team" yaw="-90">-60,9,-4</post>
        <post id="red-post-magenta-flag" owner="red-team" recover-time="7s" respawn-time="0.1s" pickup-filter="blue-team" yaw="-90">-60,9,-1</post>
        <net id="red-net-blue-flag" region="red-net" post="red-post-blue-flag" flag="blue-flag" capture-filter="red-team" respawn-filter="always" location="-59.5,9,-2.5"/>
        <net id="red-net-red-flag" region="red-net" post="red-post-red-flag" flag="red-flag" capture-filter="red-team" respawn-filter="always" location="-59.5,9,-2.5"/>
        <net id="red-net-cyan-flag" region="red-net" post="red-post-cyan-flag" flag="cyan-flag" capture-filter="red-team" respawn-filter="always" location="-59.5,9,-2.5"/>
        <net id="red-net-yellow-flag" region="red-net" post="red-post-yellow-flag" flag="yellow-flag" capture-filter="red-team" respawn-filter="always" location="-59.5,9,-2.5"/>
        <net id="red-net-magenta-flag" region="red-net" post="red-post-magenta-flag" flag="magenta-flag" capture-filter="red-team" respawn-filter="always" location="-59.5,9,-2.5"/>
    </flags>
    <filters>
        <!--
            These filters are required as opposed to using blue-team/red-team
            on the team coloured flags so they aren't separated as team-specific
            objectives on the scoreboard.
        -->
        <not id="deny-blue-own-pickup">
            <all>
                <team>blue-team</team>
                <flag-returned post="blue-post-blue-flag">blue-flag</flag-returned>
            </all>
        </not>
        <not id="deny-red-own-pickup">
            <all>
                <team>red-team</team>
                <flag-returned post="red-post-red-flag">red-flag</flag-returned>
            </all>
        </not>
        <time id="begin-release-1">1m00s</time>
        <time id="begin-release-2">3m00s</time>
        <time id="begin-release-3">5m00s</time>
        <any id="cyan-flag-at-team-post">
            <flag-returned id="blue-owns-cyan-flag" post="blue-post-cyan-flag">cyan-flag</flag-returned>
            <flag-returned id="red-owns-cyan-flag" post="red-post-cyan-flag">cyan-flag</flag-returned>
        </any>
        <any id="yellow-flag-at-team-post">
            <flag-returned id="blue-owns-yellow-flag" post="blue-post-yellow-flag">yellow-flag</flag-returned>
            <flag-returned id="red-owns-yellow-flag" post="red-post-yellow-flag">yellow-flag</flag-returned>
        </any>
        <any id="magenta-flag-at-team-post">
            <flag-returned id="blue-owns-magenta-flag" post="blue-post-magenta-flag">magenta-flag</flag-returned>
            <flag-returned id="red-owns-magenta-flag" post="red-post-magenta-flag">magenta-flag</flag-returned>
        </any>
        <flag-returned id="blue-owns-blue-flag" post="blue-post-blue-flag">blue-flag</flag-returned>
        <flag-returned id="red-owns-blue-flag" post="red-post-blue-flag">blue-flag</flag-returned>
        <flag-returned id="blue-owns-red-flag" post="blue-post-red-flag">red-flag</flag-returned>
        <flag-returned id="red-owns-red-flag" post="red-post-red-flag">red-flag</flag-returned>
        <pulse id="flag-not-released" period="1s" duration="0.5" filter="all(participating, any(all(cyan-flag-alert, not(cyan_flag_release=9..)), all(yellow-flag-alert, not(yellow_flag_release=9..)), all(magenta-flag-alert, not(magenta_flag_release=9..))))"/>
        <any id="carrying-any-flag">
            <carrying-flag>cyan-flag</carrying-flag>
            <carrying-flag>yellow-flag</carrying-flag>
            <carrying-flag>magenta-flag</carrying-flag>
            <carrying-flag>blue-flag</carrying-flag>
            <carrying-flag>red-flag</carrying-flag>
        </any>
        <if min-server-version="1.12.11">
            <entity id="display-entity">item display</entity>
        </if>
    </filters>
    <actions>
        <action id="pick-next-flag" scope="match">
            <set var="t" value="min(cyan_flag_release, magenta_flag_release, yellow_flag_release)"/>
            <!--
                Value 9 indicates that a flag has been enabled for release. We don't
                want to subtract from the var once it has been released otherwise it
                messes with the scoreboard filtering.
            -->
            <action filter="not(cyan_flag_release=9..)">
                <set var="cyan_flag_release" value="cyan_flag_release - t"/>
            </action>
            <action filter="not(yellow_flag_release=9..)">
                <set var="yellow_flag_release" value="yellow_flag_release - t"/>
            </action>
            <action filter="not(magenta_flag_release=9..)">
                <set var="magenta_flag_release" value="magenta_flag_release - t"/>
            </action>
            <action filter="cyan_flag_release=0">
                <set var="cyan_flag_release" value="9"/>
            </action>
            <action filter="yellow_flag_release=0">
                <set var="yellow_flag_release" value="9"/>
            </action>
            <action filter="magenta_flag_release=0">
                <set var="magenta_flag_release" value="9"/>
            </action>
        </action>
        <trigger scope="match" filter="begin-release-1" action="pick-next-flag"/>
        <trigger scope="match" filter="begin-release-2" action="pick-next-flag"/>
        <trigger scope="match" filter="begin-release-3" action="pick-next-flag"/>
        <trigger scope="match" filter="cyan_flag_release=9">
            <action>
                <message text="`3Cyan Flag `rwill be released in `b30 seconds"/>
                <fill region="cyan-flag-box" material="stained glass:9" filter="stained-clay"/>
            </action>
        </trigger>
        <trigger scope="match" filter="yellow_flag_release=9">
            <action>
                <message text="`eYellow Flag `rwill be released in `b30 seconds"/>
                <fill region="yellow-flag-box" material="stained glass:4" filter="stained-clay"/>
            </action>
        </trigger>
        <trigger scope="match" filter="magenta_flag_release=9">
            <action>
                <message text="`dMagenta Flag `rwill be released in `b30 seconds"/>
                <fill region="magenta-flag-box" material="stained glass:2" filter="stained-clay"/>
            </action>
        </trigger>
        <trigger scope="match">
            <filter>
                <after message="Cyan Flag will be released in {0}" duration="30s" filter="cyan_flag_release=9"/>
            </filter>
            <action>
                <message text="`3Cyan Flag `rhas been released"/>
                <fill region="cyan-flag-box" material="air" filter="stained-glass"/>
                <set var="cyan_flag_release" value="10"/>
                <if min-server-version="1.12.11">
                    <kill-entities filter="all(display-entity, cyan-flag-box)"/>
                </if>
                <sound preset="OBJECTIVE_MODE"/>
            </action>
        </trigger>
        <trigger scope="match">
            <filter>
                <after  message="Yellow Flag will be released in {0}" duration="30s" filter="yellow_flag_release=9"/>
            </filter>
            <action>
                <message text="`eYellow Flag `rhas been released"/>
                <fill region="yellow-flag-box" material="air" filter="stained-glass"/>
                <set var="yellow_flag_release" value="10"/>
                <if min-server-version="1.12.11">
                    <kill-entities filter="all(display-entity, yellow-flag-box)"/>
                </if>
                <sound preset="OBJECTIVE_MODE"/>
            </action>
        </trigger>
        <trigger scope="match">
            <filter>
                <after message="Magenta Flag will be released in {0}" duration="30s" filter="magenta_flag_release=9"/>
            </filter>
            <action>
                <message text="`dMagenta Flag `rhas been released"/>
                <fill region="magenta-flag-box" material="air" filter="stained-glass"/>
                <set var="magenta_flag_release" value="10"/>
                <if min-server-version="1.12.11">
                    <kill-entities filter="all(display-entity, magenta-flag-box)"/>
                </if>
                <sound preset="OBJECTIVE_MODE"/>
            </action>
        </trigger>
        <trigger scope="player" filter="flag-not-released">
            <action>
                <message actionbar="`c`lThis flag has not been released yet"/>
            </action>
        </trigger>
        <set id="increase-blue-score" scope="match" var="blue_score" value="blue_score+1"/>
        <set id="increase-red-score" scope="match" var="red_score" value="red_score+1"/>
        <set id="decrease-red-score" scope="match" var="red_score" value="red_score-1"/>
        <set id="decrease-blue-score" scope="match" var="blue_score" value="blue_score-1"/>
        <trigger scope="match" filter="all(blue-owns-blue-flag, not(flag_last_owner[0]=1))">
            <action>
                <action id="increase-blue-score"/>
                <action filter="flag_last_owner[0]=2">
                    <action id="decrease-red-score"/>
                </action>
                <set var="flag_last_owner" index="0" value="1"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(blue-owns-red-flag, not(flag_last_owner[1]=1))">
            <action>
                <action id="increase-blue-score"/>
                <action filter="flag_last_owner[1]=2">
                    <action id="decrease-red-score"/>
                </action>
                <set var="flag_last_owner" index="1" value="1"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(blue-owns-cyan-flag, not(flag_last_owner[2]=1))">
            <action>
                <action id="increase-blue-score"/>
                <action filter="flag_last_owner[2]=2">
                    <action id="decrease-red-score"/>
                </action>
                <set var="flag_last_owner" index="2" value="1"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(blue-owns-yellow-flag, not(flag_last_owner[3]=1))">
            <action>
                <action id="increase-blue-score"/>
                <action filter="flag_last_owner[3]=2">
                    <action id="decrease-red-score"/>
                </action>
                <set var="flag_last_owner" index="3" value="1"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(blue-owns-magenta-flag, not(flag_last_owner[4]=1))">
            <action>
                <action id="increase-blue-score"/>
                <action filter="flag_last_owner[4]=2">
                    <action id="decrease-red-score"/>
                </action>
                <set var="flag_last_owner" index="4" value="1"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(red-owns-blue-flag, not(flag_last_owner[0]=2))">
            <action>
                <action id="increase-red-score"/>
                <action filter="flag_last_owner[0]=1">
                    <action id="decrease-blue-score"/>
                </action>
                <set var="flag_last_owner" index="0" value="2"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(red-owns-red-flag, not(flag_last_owner[1]=2))">
            <action>
                <action id="increase-red-score"/>
                <action filter="flag_last_owner[1]=1">
                    <action id="decrease-blue-score"/>
                </action>
                <set var="flag_last_owner" index="1" value="2"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(red-owns-cyan-flag, not(flag_last_owner[2]=2))">
            <action>
                <action id="increase-red-score"/>
                <action filter="flag_last_owner[2]=1">
                    <action id="decrease-blue-score"/>
                </action>
                <set var="flag_last_owner" index="2" value="2"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(red-owns-yellow-flag, not(flag_last_owner[3]=2))">
            <action>
                <action id="increase-red-score"/>
                <action filter="flag_last_owner[3]=1">
                    <action id="decrease-blue-score"/>
                </action>
                <set var="flag_last_owner" index="3" value="2"/>
            </action>
        </trigger>
        <trigger scope="match" filter="all(red-owns-magenta-flag, not(flag_last_owner[4]=2))">
            <action>
                <action id="increase-red-score"/>
                <action filter="flag_last_owner[4]=1">
                    <action id="decrease-blue-score"/>
                </action>
                <set var="flag_last_owner" index="4" value="2"/>
            </action>
        </trigger>
        <trigger scope="match" filter="always">
            <action>
                <set var="cyan_flag_release" value="random()"/>
                <set var="magenta_flag_release" value="random()"/>
                <set var="yellow_flag_release" value="random()"/>
            </action>
        </trigger>
        <trigger scope="team" filter="match-started">
            <action>
                <set var="score" value="1"/>
            </action>
        </trigger>
    </actions>
</if>
