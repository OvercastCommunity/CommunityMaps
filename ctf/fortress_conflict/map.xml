<map proto="1.5.1">
<version>1.0.2</version>
<name>Fortress Conflict</name>
<objective>Capture each of the enemy's flags to win!</objective>
<created>2026-05-24</created>
<gamemode>ctf</gamemode>
<phase>staging</phase>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="4d6ecfd1-2e0e-49b6-83c6-e230efe448d4"/> <!-- 3lii3 -->
    <author uuid="9c14b7e9-8488-427a-bc81-7193becde2d3" contribution="Built some decorations."/> <!-- MrTinyPig -->
</authors>
<contributors>
    <contributor uuid="64e840c8-4fb5-4659-a36b-ff93e2f6113a" contribution="Restructured map and rewritten code."/> <!-- Javg_ -->
    <contributor uuid="fe3608b7-d105-4029-8800-34b3147065b6" contribution="Helped with XML."/> <!-- rockymine -->
    <contributor uuid="b20bd5cf-f810-4efc-92eb-218412c692d5" contribution="Built 6.7% of the map."/> <!-- pianomaxxer -->
</contributors>
<maxbuildheight>24</maxbuildheight>
<teams>
    <team id="cyan-team" plural="true" color="dark aqua" max="20">Creepoids</team>
    <team id="orange-team" plural="true" color="gold" max="20">Skeletals</team>
</teams>
<kits>
    <kit id="tanker-kit">
        <clear items="false" armor="true" effects="true"/>
        <item slot="0" material="wood sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true"/>
        <item slot="2" material="wool" team-color="true" amount="32"/>
        <item slot="3" material="stained glass" team-color="true" amount="32"/>
        <item slot="7" material="shears" unbreakable="true" />
        <item slot="8" material="golden apple" amount="1"/>
        <item slot="28" material="arrow" amount="12"/>
        <helmet material="iron helmet" locked="true"/>
        <chestplate team-color="true" material="leather chestplate" locked="true"/>
        <leggings team-color="true" material="iron leggings" locked="true"/>
        <boots material="iron boots" locked="true"/>
        <effect>slowness</effect>
        <max-health>20</max-health>
    </kit>
    <kit id="assault-kit">
        <clear items="false" armor="true" effects="true"/>
        <item slot="0" material="stone sword" unbreakable="true">
            <enchantment level="1">sharpness</enchantment>
        </item>
        <item slot="1" material="bow" unbreakable="true">
            <enchantment level="1">power</enchantment>
        </item>
        <item slot="2" material="wool" team-color="true" amount="64"/>
        <item slot="3" material="stained glass" team-color="true" amount="64"/>
        <item slot="7" material="shears" unbreakable="true" />
        <item slot="8" material="golden apple" amount="1"/>
        <item slot="28" material="arrow" amount="36"/>
        <helmet material="iron helmet" locked="true"/>
        <chestplate team-color="true" material="leather chestplate" locked="true" prevent-sharing="true"/>
        <leggings team-color="true" material="leather leggings" locked="true" prevent-sharing="true"/>
        <boots team-color="true" material="leather boots" locked="true" prevent-sharing="true"/>
        <effect>speed</effect>
        <max-health>16</max-health>
    </kit>
    <kit id="defense-kit">
        <clear items="false" armor="true" effects="true"/>
        <item slot="0" material="stone sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true"/>
        <item slot="2" material="wool" team-color="true" amount="64"/>
        <item slot="3" material="stained glass" team-color="true" amount="64"/>
        <item slot="4" material="stained glass" team-color="true" amount="32"/>
        <item slot="7" material="shears" unbreakable="true" >
            <enchantment level="2">efficiency</enchantment>
        </item>
        <item slot="8" material="golden apple" amount="1"/>
        <item slot="28" material="arrow" amount="64"/>
        <helmet material="chainmail helmet" locked="true"/>
        <chestplate team-color="true" material="leather chestplate" locked="true" prevent-sharing="true"/>
        <leggings team-color="true" material="chainmail leggings" locked="true" prevent-sharing="true"/>
        <boots team-color="true" material="leather boots" locked="true" prevent-sharing="true"/>
        <max-health>20</max-health>
    </kit>
    <kit id="pickup-kit">
        <clear items="false" armor="true" effects="true"/>
        <chestplate color="FFFFFF" material="leather chestplate" locked="true" prevent-sharing="true"/>
        <leggings team-color="true" material="leather leggings" locked="true" prevent-sharing="true"/>
        <boots team-color="true" material="leather boots" locked="true" prevent-sharing="true"/>
        <effect>speed</effect>
        <effect duration="10s">absorption</effect>
    </kit>
    <kit id="drop-kit">
        <action id="apply-class-armor"/>
    </kit>
</kits>
<spawns>
    <default yaw="180" region="default-spawn-point"/>
    <spawn team="cyan-team" yaw="90" region="cyan-spawn-point"/>
    <spawn team="orange-team" yaw="-90" region="orange-spawn-point"/>
</spawns>
<filters>
    <any id="only-player-blocks">
        <material>orange wool</material>
        <material>cyan wool</material>
        <material>orange stained glass</material>
        <material>cyan stained glass</material>
    </any>
    <deny id="deny-redstone">
        <any>
            <material>redstone wire</material>
        </any>
    </deny>
    <class id="has-tanker">Tanker</class>
    <class id="has-assault">Assault</class>
    <class id="has-defender">Defender</class>
</filters>
<actions>
    <action scope="player" id="apply-class-armor">
        <action filter="has-assault">
            <kit id="assault-kit"/>
        </action>
        <action filter="has-tanker">
            <kit id="tanker-kit"/>
        </action>
        <action filter="has-defender">
            <kit id="defense-kit"/>
        </action>
    </action>
</actions>
<classes family="default">
    <class name="Tanker"
           description="Worse everything, better armor. Great for carrier protection."
           icon="iron boots"
           >
        <kit id="tanker-kit"/>
    </class>
    <class name="Assault"
           description="Less protection, more agile. Great for rushing."
           icon="iron sword"
           default="true"
           >
        <kit id="assault-kit"/>
    </class>
    <class name="Defender"
           description="Mild protection, more blocks. Great for defending flag."
           icon="wool"
           >
        <kit id="defense-kit"/>
    </class>
</classes>
<regions>
    <point id="default-spawn-point">0.5,37,0.5</point>
    <point id="orange-spawn-point">-93.5,22,-64.5</point>
    <point id="cyan-spawn-point">94.5,22,-64.5</point>
    <cuboid id="orange-capture" min="-96,22,-67" max="-91,25,-62"/>
    <cuboid id="cyan-capture" min="97,22,-67" max="92,25,-62"/>
    <union id="spawns">
        <rectangle id="orange-spawn" min="-76,-56" max="-98,-73"/>
        <rectangle id="cyan-spawn" min="77,-56" max="98,-73"/>
    </union>
    <negative id="outside-buildable-area">
        <union id="buildable-area">
            <rectangle min="-98,-27" max="-52,-102"/>
            <rectangle min="-20,-102" max="21,-27"/>
            <rectangle min="99,-27" max="53,-102"/>
            <rectangle min="-52,-27" max="53,-43"/>
            <rectangle min="-52,-86" max="53,-102"/>
            <rectangle min="-52,-73" max="53,-56"/>
        </union>
    </negative>
    <union id="flags-region">
        <cuboid min="-83,7,-87" max="-88,15,-92"/>
        <cuboid min="-83,7,-37" max="-88,15,-42"/>
        <cuboid min="84,7,-87" max="89,15,-92"/>
        <cuboid min="84,7,-37" max="89,15,-42"/>
    </union>
    <apply enter="orange-team" region="orange-spawn" message="You cannot enter other team's spawn!"/>
    <apply enter="cyan-team" region="cyan-spawn" message="You cannot enter other team's spawn!"/>
    <apply block="never" region="flags-region" message="You may not edit the flags area!"/>
    <apply block="never" region="spawns" message="You may not edit the spawn area!"/>
    <apply block="never" region="outside-buildable-area" message="You may only build in marked areas!"/>
    <apply block="only-player-blocks" message="You can only break player-placed blocks!"/>
    <apply block-physics="deny-redstone" region="outside-buildable-area"/>
</regions>
<flags>
    <flags owner="orange-team" pickup-filter="cyan-team" pickup-kit="pickup-kit" drop-on-water="false" drop-kit="drop-kit">
        <flag id="alpha-flag" name="Alpha Flag" color="orange">
            <post recover-time="12s">-86,8,-90</post>        
        </flag>
        <flag id="beta-flag" name="Beta Flag" color="red">    
            <post recover-time="12s">-86,8,-40</post>
        </flag>
    </flags>
    <flags owner="cyan-team" pickup-filter="orange-team" pickup-kit="pickup-kit" drop-on-water="false" drop-kit="drop-kit">
        <flag id="delta-flag" name="Delta Flag" color="light blue">
            <post recover-time="12s">86,8,-90</post>        
        </flag>
        <flag id="omega-flag" name="Omega Flag" color="cyan">    
            <post recover-time="12s">86,8,-40</post>
        </flag>
    </flags>
    <net region="cyan-capture" flags="alpha-flag beta-flag" capture-filter="cyan-team" post="cyan-monument"/>
    <net region="orange-capture" flags="delta-flag omega-flag" capture-filter="orange-team" post="orange-monument"/>
    <flags permanent="true" sequential="true">
        <post id="cyan-monument" owner="cyan-team" yaw="90">
            <block>94,23,-60</block>
            <block>94,23,-70</block>
        </post>
        <post id="orange-monument" owner="orange-team" yaw="-90">
            <block>-94,23,-60</block>
            <block>-94,23,-70</block>
        </post>
    </flags>
</flags>
<itemremove>
    <item>iron helmet</item>
    <item>chainmail helmet</item>
    <item>leather boots</item>
    <item>iron boots</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>iron leggings</item>
    <item>chainmail leggings</item>
    <item>stick</item>
    <item>wood</item>
    <item>wood sword</item>
    <item>stone sword</item>
    <item>bow</item>
    <item>shears</item>
    <item>arrow</item>
</itemremove>
<itemkeep>
    <item>stained glass</item>
    <item>wool</item>
    <item>golden apple</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item material="wool" team-color="true" amount="8"/>
        <item material="stained glass" team-color="true" amount="8"/>
        <item material="arrow" amount="8"/>
    </kill-reward>
</kill-rewards>
<item-mods>
    <rule>
        <match>
            <material>iron boots</material>
            <material>leather boots</material>
        </match>
        <modify>
            <enchantment level="2">feather falling</enchantment>
        </modify>
    </rule>
</item-mods>
<gamerules>
    <randomTickSpeed>0</randomTickSpeed>
</gamerules>
<hunger>
    <depletion>off</depletion>
</hunger>
<respawn delay="3s"/>
</map>