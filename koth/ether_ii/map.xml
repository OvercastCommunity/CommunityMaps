<map proto="1.5.0">
<name>Ether II</name>
<version>1.0.0</version>
<objective>Reach 2500 points before the opposing team!</objective>
<created>2025-07-04</created>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="f610e558-a3c8-44fb-8622-68cc49dbc18f"/> <!-- jcane -->
</authors>
<teams>
    <team id="blue" color="blue" max="20" max-overfill="20">Blue</team>
    <team id="red" color="dark red" max="20" max-overfill="20">Red</team>
</teams>
<score>
    <limit>2500</limit>
</score>
<kits>
    <kit id="conquest">
        <clear/>
        <item slot="0" unbreakable="true" material="stone sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="2" material="golden apple"/>
        <item slot="8" amount="8" material="arrow"/>
        <helmet locked="true" unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate locked="true" unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings locked="true" unbreakable="true" material="chainmail leggings">
            <enchantment level="4">projectile_protection</enchantment>
        </leggings>
        <boots locked="true" unbreakable="true" material="iron boots">
            <enchantment>feather_falling</enchantment>
            <enchantment>fire_protection</enchantment>
        </boots>
        <effect duration="1s" amplifier="0">health boost</effect>
        <effect duration="1s" amplifier="10">regeneration</effect>
        <game-mode>adventure</game-mode>
    </kit>
    <kit id="spawn-kit" parent="conquest">
        <effect duration="5s" amplifier="255">resistance</effect>
    </kit>
</kits>
<spawns>
    <default region="default-spawn" yaw="180"/>
    <spawn team="blue" kit="spawn-kit" region="blue-spawn" yaw="0"/>
    <spawn team="red" kit="spawn-kit" region="red-spawn" yaw="0"/>
</spawns>
<regions>
    <cuboid id="north" min="-3,19,-110" max="4,70,-103"/>
    <cuboid id="middle" min="-3,15,-76" max="4,70,-69"/>
    <cuboid id="south" min="-3,9,-40" max="4,70,-33"/>
    <point id="default-spawn">0.4,22,-6.5</point>
    <point id="blue-spawn">57.5,20,-81.5</point>
    <point id="red-spawn">-56.5,20,-81.5</point>
</regions>
<control-points capture-time="5s" points="3" show-progress="true" neutral-state="true" incremental="true" required="false">
    <control-point name="North" capture="north" progress="north" />
    <control-point name="Middle" capture="middle" progress="middle" />
    <control-point name="South" capture="south" progress="south" />
</control-points>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>iron boots</item>
</itemremove>
<itemkeep>
    <item>golden apple</item>
    <item>arrow</item>
</itemkeep>
<hunger>
    <depletion>off</depletion>
</hunger>
<kill-reward>
    <item amount="4" material="arrow"/>
</kill-reward>
<damage>
    <deny>
        <cause>fall</cause>
    </deny>
</damage>
</map>
