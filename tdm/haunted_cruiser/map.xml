<map proto="1.5.0">
<name>Haunted Cruiser</name>
<version>1.0.0</version>
<phase>staging</phase>
<objective>Get the most kills in 12 minutes!</objective>
<created>2026-04-13</created>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="644521d7-9437-47c1-b1d2-698eb757df3d"/> <!-- minuyo -->
</authors>
<contributors>
    <contributor uuid="63ddf58a-ba2c-4d39-8481-6358bb46c63a" contribution="xml"/> <!-- samschaap -->
</contributors>
<teams>
    <team id="orange-team" color="gold" max="24">Orange</team>
    <team id="cyan-team" color="dark aqua" max="24">Cyan</team>
</teams>
<time>12m</time>
<score>
    <kills>1</kills>
    <box points="10" filter="cyan-team" region="orange-scorebox"/>
    <box points="10" filter="orange-team" region="cyan-scorebox"/>
</score>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="stone sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="2" material="arrow" amount="16"/>
        <item slot="8" material="golden apple"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" color="33333F" material="leather leggings"/>
        <boots unbreakable="true" color="262626" material="leather boots"/>
        <effect duration="4s" amplifier="255">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <default yaw="-90">
        <region>
            <point>-79.5,75,0.5</point>
        </region>
    </default>
    <spawn team="orange-team" kit="spawn-kit" region="orange-spawnpoint" yaw="0"/>
    <spawn team="cyan-team" kit="spawn-kit" region="cyan-spawnpoint" yaw="180"/>
</spawns>
<filters>
    <any id="only-lever-or-world">
        <material id="only-lever">lever</material>
        <cause id="only-world">world</cause>
    </any>
    <deny id="deny-some">
        <any>
            <participating/>
            <cause>mob</cause>
        </any>
    </deny>
    <after id="lever-1-after-5-seconds" duration="5s">
        <offset vector="-4,13,-94" filter="only-lever"/>
    </after>
    <after id="lever-2-after-5-seconds" duration="5s">
        <offset vector="4,13,-94" filter="only-lever"/>
    </after>
    <after id="lever-3-after-5-seconds" duration="5s">
        <offset vector="-13,12,-37" filter="only-lever"/>
    </after>
    <after id="lever-4-after-5-seconds" duration="5s">
        <offset vector="11,11,-24" filter="only-lever"/>
    </after>
    <after id="lever-5-after-5-seconds" duration="5s">
        <offset vector="5,27,-58" filter="only-lever"/>
    </after>
    <after id="lever-6-after-5-seconds" duration="5s">
        <offset vector="12,22,-45" filter="only-lever"/>
    </after>
    <after id="lever-7-after-5-seconds" duration="5s">
        <offset vector="6,29,-15" filter="only-lever"/>
    </after>
    <after id="lever-8-outside-after-5-seconds" duration="5s">
        <offset vector="-14,24,-38" filter="only-lever"/>
    </after>
    <after id="lever-8-inside-after-5-seconds" duration="5s">
        <offset vector="-16,24,-38" filter="only-lever"/>
    </after>
    <after id="lever-9-after-5-seconds" duration="5s">
        <offset vector="4,13,94" filter="only-lever"/>
    </after>
    <after id="lever-10-after-5-seconds" duration="5s">
        <offset vector="-4,13,94" filter="only-lever"/>
    </after>
    <after id="lever-11-after-5-seconds" duration="5s">
        <offset vector="13,12,37" filter="only-lever"/>
    </after>
    <after id="lever-12-after-5-seconds" duration="5s">
        <offset vector="-11,11,24" filter="only-lever"/>
    </after>
    <after id="lever-13-after-5-seconds" duration="5s">
        <offset vector="-5,27,58" filter="only-lever"/>
    </after>
    <after id="lever-14-after-5-seconds" duration="5s">
        <offset vector="-12,22,45" filter="only-lever"/>
    </after>
    <after id="lever-15-after-5-seconds" duration="5s">
        <offset vector="-6,29,15" filter="only-lever"/>
    </after>
    <after id="lever-16-outside-after-5-seconds" duration="5s">
        <offset vector="14,24,38" filter="only-lever"/>
    </after>
    <after id="lever-16-inside-after-5-seconds" duration="5s">
        <offset vector="16,24,38" filter="only-lever"/>
    </after>
    <pulse id="trigger-thunder-sound" period="25s" duration="1s">
        <after duration="5s">
            <match-running/>
        </after>
    </pulse>
</filters>
<actions>
    <trigger filter="lever-1-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-1" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-2-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-2" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-3-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-3" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-4-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-4" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-5-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-5" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-6-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-6" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-7-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-7" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-8-outside-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-8-outside" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-8-inside-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-8-inside" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-9-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-9" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-10-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-10" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-11-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-11" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-12-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-12" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-13-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-13" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-14-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-14" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-15-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-15" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-16-outside-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-16-outside" events="true"/>
        </action>
    </trigger>
    <trigger filter="lever-16-inside-after-5-seconds" scope="match">
        <action>
            <fill material="air" region="lever-16-inside" events="true"/>
        </action>
    </trigger>
    <trigger filter="trigger-thunder-sound" scope="match">
        <action>
            <sound key="${entity.lightning_bolt.thunder}"/>
        </action>
    </trigger>
</actions>
<regions>
    <point id="orange-spawnpoint">0.5,17,-91.5</point>
    <point id="cyan-spawnpoint">0.5,17,92.5</point>
    <point id="gapple-spawnpoint">0.5,7,0.5</point>
    <cylinder id="gapple-spawner" base="0.5,7,0.5" radius="2" height="1"/>
    <union id="levers">
        <!-- Orange side -->
        <block id="lever-1">-4,13,-94</block>
        <block id="lever-2">4,13,-94</block>
        <block id="lever-3">-13,12,-37</block>
        <block id="lever-4">11,11,-24</block>
        <block id="lever-5">5,27,-58</block>
        <block id="lever-6">12,22,-45</block>
        <block id="lever-7">6,29,-15</block>
        <block id="lever-8-outside">-14,24,-38</block>
        <block id="lever-8-inside">-16,24,-38</block>
        <!-- Cyan side -->
        <block id="lever-9">4,13,94</block>
        <block id="lever-10">-4,13,94</block>
        <block id="lever-11">13,12,37</block>
        <block id="lever-12">-11,11,24</block>
        <block id="lever-13">-5,27,58</block>
        <block id="lever-14">-12,22,45</block>
        <block id="lever-15">-6,29,15</block>
        <block id="lever-16-outside">14,24,38</block>
        <block id="lever-16-inside">16,24,38</block>
    </union>
    <union id="scoreboxes">
        <cuboid id="orange-scorebox" min="-10,11,-89" max="11,12,-92"/>
        <cuboid id="cyan-scorebox" min="11,11,90" max="-10,12,93"/>
    </union>
    <union id="orange-scorebox-protection">
        <cuboid min="-11,10,-87" max="-6,20,-93"/>
        <cuboid min="7,10,-87" max="12,20,-93"/>
    </union>
    <union id="cyan-scorebox-protection">
        <cuboid min="12,10,88" max="7,20,94"/>
        <cuboid min="-6,10,88" max="-11,20,94"/>
    </union>
    <apply enter="cyan-team" region="orange-scorebox-protection" message="You may not enter your own team's scorebox!"/>
    <apply enter="orange-team" region="cyan-scorebox-protection" message="You may not enter your own team's scorebox!"/>
    <apply block="only-lever-or-world" region="levers"/>
    <apply block="deny-some"/>
</regions>
<portals>
    <portal filter="cyan-team" region="orange-scorebox" destination="cyan-spawnpoint" yaw="@180"/>
    <portal filter="orange-team" region="cyan-scorebox" destination="orange-spawnpoint" yaw="@0"/>
</portals>
<spawners>
    <spawner spawn-region="gapple-spawnpoint" player-region="gapple-spawner" max-entities="1" delay="7s">
        <item material="golden apple"/>
    </spawner>
</spawners>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>rotten flesh</item>
    <item>sulphur</item>
    <item>lever</item>
</itemremove>
<itemkeep>
    <item>arrow</item>
    <item>golden apple</item>
</itemkeep>
<friendlyfire>on</friendlyfire>
<damage>
    <deny>
        <all>
            <any>
                <all>
                    <attacker>
                        <team>cyan-team</team>
                    </attacker>
                    <victim>
                        <team>cyan-team</team>
                    </victim>
                </all>
                <all>
                    <attacker>
                        <team>orange-team</team>
                    </attacker>
                    <victim>
                        <team>orange-team</team>
                    </victim>
                </all>
            </any>
            <not>
                <cause>potion</cause>
            </not>
        </all>
    </deny>
</damage>
<kill-rewards>
    <kill-reward>
        <item amount="8" material="arrow"/>
    </kill-reward>
    <kill-reward>
        <filter>
            <kill-streak count="3" repeat="true"/>
        </filter>
        <item material="lever">
            <can-place-on>
                <material>gold block</material>
            </can-place-on>
        </item>
    </kill-reward>
</kill-rewards>
<broadcasts>
    <tip after="10s" every="2m">After `e3`r kills, you will receive 1 `7Lever`r!</tip>
    <tip after="11s" every="2m">You can place `7Levers`r on `eGold Blocks`r!</tip>
</broadcasts>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
