<map proto="1.5.0">
<name>Dreamland</name>
<version>1.0.0</version>
<include id="gapple-kill-reward"/>
<objective>Capture the other team's wool!</objective>
<created>2025-11-15</created>
<phase>staging</phase>
<gamemode>ctw</gamemode>
<authors>
    <author uuid="4a37724d-5cf6-4d27-b739-186ab66b9d75"/> <!-- katanyaa -->
    <author uuid="c3380cc1-9b82-41be-ac21-cf82cfde5bea"/> <!-- orview -->
    <author uuid="79581014-09b0-4fbf-a388-aa4ba42c0bc2"/> <!-- crazymc98 -->
</authors>
<constants>
    <constant id="observers-kit" delete="true"/>
</constants>
<teams>
    <team id="pink" color="light purple" max="32">Pink</team>
    <team id="blue" color="blue" max="32">Blue</team>
</teams>
<spawns>
    <default kit="${observers-kit}" yaw="90">
        <regions>
            <point>120.5,71,0.5</point>
        </regions>
    </default>
    <spawn team="blue" kit="spawn-kit" yaw="0" region="blue-spawnpoint"/>
    <spawn team="pink" kit="spawn-kit" yaw="180" region="pink-spawnpoint"/>
</spawns>
<kits>s
    <kit id="speed-kit">
        <effect amplifier="2">speed</effect>
    </kit>
    <kit id="default-kit">
        <effect>night vision</effect>
    </kit>
    <kit id="spawn-kit" parent="speed-kit">
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="2" unbreakable="true" material="iron pickaxe"/>
        <item slot="3" unbreakable="true" material="iron axe"/>
        <item slot="4" material="water bucket"/>
        <item slot="5" material="wood" damage="2" amount="64"/>
        <item slot="6" material="stained glass" team-color="true" amount="64"/>
        <item slot="7" material="golden apple"/>
        <item slot="28" material="arrow" amount="48"/>
        <item slot="29" unbreakable="true" material="stone spade"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" team-color="true" material="leather leggings"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
        <effect duration="oo" amplifier="1">night vision</effect>
        <effect duration="6" amplifier="255">damage resistance</effect>
    </kit>
    <take kit="speed-kit">
        <filter>
            <not>
                <region id="spawns"/>
            </not>
        </filter>
    </take>
</kits>
<filters>
    <all id="only-iron-renew">
        <material id="only-iron">iron block</material>
        <cause>world</cause>
    </all>
    <!--Territory Filters-->
    <all id="blue-in-wr">
        <team id="only-blue">blue</team>
    </all>
    <all id="pink-in-wr">
        <team id="only-pink">pink</team>
    </all>  
</filters>
<regions>
    <point id="blue-spawnpoint">0.5,13,-155</point>
    <point id="pink-spawnpoint">0.5,13,156</point>
    <union id="spawns">
        <cuboid id="blue-protection" min="22,0,-122" max="-21,oo,-180"/>
        <cuboid id="pink-protection" min="22,0,123" max="-21,oo,181"/>
        <cuboid id="blue-protection2" min="16,0,-84" max="-15,oo,-122"/>
        <cuboid id="pink-protection2" min="16,0,85" max="-15,oo,123"/>
        <cuboid id="blue-protection3" min="27,7,-107" max="-26,oo,-115"/>
        <cuboid id="pink-protection3" min="27,7,108" max="-26,oo,116"/>
    </union>
    <union id="lanes">
        <rectangle id="east" min="21, -92" max="79,93"/>
        <rectangle id="west" min="-20, -92" max="-78,93"/>
        <rectangle id="middle" min="-20, -85" max="21,86"/>
    </union>
    <union id="pits">
        <rectangle id="lime-pit" min="61, 140" max="76,129"/>
        <rectangle id="cyan-pit" min="-60, 140" max="-75,129"/>
        <rectangle id="purple-pit" min="61, -139" max="76,-128"/>
        <rectangle id="magenta-pit" min="-60, -139" max="-75,-128"/>
    </union>
    <union id="wool-rooms">
        <union id="pink-wool-rooms"> <!-- Blue defends -->
            <cuboid id="cyan-wool-room" min="-47,0,140" max="-88,oo,184"/>
            <cuboid id="lime-wool-room" min="48,0,140" max="89,oo,184"/>
        </union>
        <union id="blue-wool-rooms"> <!-- Pink defends -->
            <cuboid id="magenta-wool-room" min="-47,0,-139" max="-88,oo,-183"/>
            <cuboid id="purple-wool-room" min="48,0,-139" max="89,oo,-183"/>
        </union>
    </union>
    <union id="spawners">
        <union id="west-spawner">
            <point id="west-point">-66.5,9,0.5</point>
            <cylinder id="west-player" base="-66.5,9,0.5" radius="5" height="7"/>
        </union>
        <union id="east-spawner">
            <point id="east-point">67.5,9,0.5</point>
            <cylinder id="east-player" base="67.5,9,0.5" radius="5" height="7"/>
        </union>
        <union id="purple-spawners">
            <point id="purple-spawner-1">67.5,15,-148.5</point>
            <point id="purple-spawner-2">70.5,15,-163.5</point>
            <point id="purple-spawner-3">64.5,14,-159.5</point>            
        </union>
        <union id="magenta-spawners">
            <point id="magenta-spawner-1">-68.5,15,-148.5</point>
            <point id="magenta-spawner-2">-65.5,15,-163.5</point>
            <point id="magenta-spawner-3">-71.5,14,-159.5</point>            
        </union>
        <union id="cyan-spawners">
            <point id="cyan-spawner-1">-66.5,15,149.5</point>
            <point id="cyan-spawner-2">-69.5,15,164.5</point>
            <point id="cyan-spawner-3">-63.5,14,160.5</point>            
        </union>
        <union id="lime-spawners">
            <point id="lime-spawner-1">69.5,15,149.5</point>
            <point id="lime-spawner-2">66.5,15,164.5</point>
            <point id="lime-spawner-3">72.5,14,160.5</point>            
        </union>
    </union>
    <union id="spawner-protection">
        <cylinder id="east-spawner-protection" base="-66.5,0,0.5" radius="3" height="12"/>
        <cylinder id="west-spawner-protection" base="67.5,0,0.5" radius="3" height="12"/>
    </union>
    <negative id="void-area">
        <region id="spawns"/>
        <region id="pits"/>
        <region id="lanes"/>
        <region id="wool-rooms"/>
    </negative>
    <apply block="never" region="spawner-protection" message="You may not break or place around the spawner!"/>
    <apply block-break="only-iron" region="spawns" message="You may only break iron blocks in the spawns!"/>
    <apply block-place="only-iron-renew" region="spawns" message="You may only break iron blocks in the spawns!"/>
    <apply block-place="deny(void)" region="void-area" message="You may not build in the void area!"/>
    <apply block-break="blue-in-wr" region="pink-wool-rooms" message="You may not interact with this block!"/>
    <apply block-break="pink-in-wr" region="blue-wool-rooms" message="You may not interact with this block!"/>
    <apply block-place="deny(pink)" region="pink-wool-rooms" message="You may not interact with this block!"/>
    <apply block-place="deny(blue)" region="blue-wool-rooms" message="You may not interact with this block!"/>
    <apply enter="only-blue" region="blue-protection" message="You may not enter the opponent's spawn!"/>
    <apply enter="only-pink" region="pink-protection" message="You may not enter the opponent's spawn!"/>
    <apply enter="only-blue" region="pink-wool-rooms" message="You may not enter your own wool room!"/>
    <apply enter="only-pink" region="blue-wool-rooms" message="You may not enter your own wool room!"/>
</regions>
<spawners>
    <spawner spawn-region="east-point" player-region="east-player" delay="15s">
        <item material="golden apple" amount="1"/>
    </spawner>
    <spawner spawn-region="west-point" player-region="west-player" delay="15s">
        <item material="golden apple" amount="1"/>
    </spawner>
    <spawner spawn-region="purple-spawner-1" player-region="purple-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="10" amount="1"/>
    </spawner>
    <spawner spawn-region="purple-spawner-2" player-region="purple-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="10" amount="1"/>
    </spawner>
    <spawner spawn-region="purple-spawner-3" player-region="purple-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="10" amount="1"/>
    </spawner>
    <spawner spawn-region="magenta-spawner-1" player-region="magenta-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="2" amount="1"/>
    </spawner>
    <spawner spawn-region="magenta-spawner-2" player-region="magenta-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="2" amount="1"/>
    </spawner>
    <spawner spawn-region="magenta-spawner-3" player-region="magenta-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="2" amount="1"/>
    </spawner>
    <spawner spawn-region="cyan-spawner-1" player-region="cyan-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="9" amount="1"/>
    </spawner>
    <spawner spawn-region="cyan-spawner-2" player-region="cyan-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="9" amount="1"/>
    </spawner>
    <spawner spawn-region="cyan-spawner-3" player-region="cyan-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="9" amount="1"/>
    </spawner>
    <spawner spawn-region="lime-spawner-1" player-region="lime-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="5" amount="1"/>
    </spawner>
    <spawner spawn-region="lime-spawner-2" player-region="lime-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="5" amount="1"/>
    </spawner>
    <spawner spawn-region="lime-spawner-3" player-region="lime-wool-room" max-entities="16" delay="5s">
        <item material="wool" damage="5" amount="1"/>
    </spawner>
</spawners>
<wools craftable="false">
    <!-- Blue Team -->
    <wool team="blue" color="cyan" location="-6.5,18,-127.5">
        <monument>
            <block>-7,18,-128</block>
        </monument>
    </wool>
    <wool team="blue" color="lime" location="7.5,18,-127.5">
        <monument>
            <block>7,18,-128</block>
        </monument>
    </wool>
    <!-- Pink Team -->
    <wool team="pink" color="purple" location="7.5,18,128.5">
        <monument>
            <block>7,18,128</block>
        </monument>
    </wool>
    <wool team="pink" color="magenta" location="-6.5,18,128.5">
        <monument>
            <block>-7,18,128</block>
        </monument>
    </wool>
</wools>
<itemkeep>
    <item>iron sword</item>
    <item>bow</item>
    <item>iron pickaxe</item>
    <item>iron axe</item>
    <item>stone spade</item>
    <item>wood</item>
    <item>stained glass</item>
    <item>water bucket</item>
    <item>bucket</item>
    <item>golden apple</item>
    <item>arrow</item>
</itemkeep>
<toolrepair>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>stone spade</tool>
    <tool>iron sword</tool>
    <tool>bow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>string</item>
    <item>seeds</item>
    <item>leaves</item>
</itemremove>
<kill-rewards>
    <kill-reward>
        <item amount="16" material="wood" damage="2"/>
        <item amount="8" material="stained glass" team-color="true"/>
        <item amount="16" material="arrow"/>
    </kill-reward>
</kill-rewards>
<renewables>
    <renewable region="spawns" renew-filter="only-iron" rate="0.7"/>
</renewables>
<maxbuildheight>28</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>