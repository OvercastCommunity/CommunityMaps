<map proto="1.5.0">
<name>Station X</name>
<version>1.0.2</version>
<objective>Capture the two wools of the enemy team!</objective>
<created>2026-01-10</created>
<phase>staging</phase>
<include id="gapple-kill-reward"/>
<include id="iron-bulkcrafting"/>
<constants>
    <constant id="unbreakable-armor">true</constant>
    <constant id="right-wool-rooms-height">58</constant>
    <constant id="left-wool-rooms-height">47</constant>
</constants>
<authors>
    <author uuid="1af9f952-e33e-42a5-8e1e-296757747fdc"/> <!-- Alphaboy98yt -->
</authors>
<contributors>
    <contributor uuid="84d0f14a-1aae-447f-838c-8ac742667d67" contribution="XML"/> <!-- limefox3054 -->
</contributors>
<teams>
    <team id="blue-team" color="blue" max="28">Blue</team>
    <team id="red-team" color="dark red" max="28">Red</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true" enchantment="infinity"/>
        <item slot="2" material="iron pickaxe" unbreakable="true" enchantment="efficiency"/>
        <item slot="3" material="iron axe" unbreakable="true"/>
        <item slot="4" material="smooth brick" amount="64" damage="3"/>
        <item slot="5" material="glass" amount="32"/>
        <item slot="7" material="water bucket"/>
        <item slot="8" material="golden apple"/>
        <item slot="28" material="arrow"/>
        <item slot="31" material="smooth brick" amount="64" damage="3"/>
        <helmet material="leather helmet" unbreakable="true" team-color="true"/>
        <chestplate material="leather chestplate" unbreakable="true" team-color="true"/>
        <leggings material="chainmail leggings" unbreakable="true" enchantment="protection projectile:2"/>
        <boots material="leather boots" unbreakable="true" team-color="true"/>
        <effect duration="3s" amplifier="5">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <spawn team="blue-team" region="blue-spawn-point" kit="spawn-kit"/>
    <spawn team="red-team" region="red-spawn-point" yaw="180" kit="spawn-kit"/>
    <default region="obs-spawn-point" yaw="90"/>
</spawns>
<filters>
    <all id="not-water-cause-world"> <!-- prevent block destruction caused by water flow -->
        <not>
            <any>
                <material>water</material>
                <material>stationary water</material>
            </any>
        </not>
        <cause>world</cause>
    </all>
    <all id="wool-rooms-blocks">
        <blocks region="wool-rooms">
            <any> <!-- breakable blocks -->
                <material>air</material>
                <material>web</material>
                <material>redstone wire</material>
            </any>
        </blocks>
        <not> <!-- non-placeable blocks -->
            <void/>
        </not>
    </all>
    <all id="only-iron-renew">
        <material id="only-iron">iron block</material>
        <cause>world</cause>
    </all>
    <completed id="pink-wool-captured">pink-wool</completed>
    <completed id="purple-wool-captured">purple-wool</completed>
    <completed id="yellow-wool-captured">yellow-wool</completed>
    <completed id="orange-wool-captured">orange-wool</completed>
    <any id="decoration">
        <material>dispenser</material>
        <material>furnace</material>
        <material>lever</material>
        <material>stone button</material>
        <material>trap door</material>
    </any>
    <material id="obsidian">obsidian</material>
    <material id="redstone">redstone wire</material>
    <material id="iron-trapdoor">iron trapdoor</material>
</filters>
<regions>
    <!-- team spawn points -->
    <cylinder id="blue-spawn-point" base="-14.5,19,-527.5" radius="1" height="0"/>
    <cylinder id="red-spawn-point" base="-15.5,19,-211.5" radius="1" height="0"/>
    <cylinder id="obs-spawn-point" base="78.5,59,-369.5" radius="2.5" height="0"/>
    <!-- victory monuments -->
    <block id="victory-monument-pink">-9,16,-514</block>
    <block id="victory-monument-purple">-21,16,-514</block>
    <block id="victory-monument-yellow">-22,16,-226</block>
    <block id="victory-monument-orange">-10,16,-226</block>
    <!-- victory monument protection areas -->
    <rectangle id="victory-monument-protection-pink" min="-7,-514" max="-10,-512"/>
    <rectangle id="victory-monument-protection-purple" min="-19,-514" max="-22,-512"/>
    <rectangle id="victory-monument-protection-yellow" min="-23,-225" max="-20,-227"/>
    <rectangle id="victory-monument-protection-orange" min="-11,-225" max="-8,-227"/>
    <!-- wool spawns -->
    <point id="pink-wool-spawn">63,12.7,-242</point>
    <point id="purple-wool-spawn">-98,16.7,-210</point>
    <point id="yellow-wool-spawn">-93,12.7,-497</point>
    <point id="orange-wool-spawn">68,16.7,-529</point>
    <union id="spawn-protections">
        <union id="blue-spawn-protection">
            <rectangle min="-1,-540" max="-28,-488"/>
            <rectangle min="-10,-489" max="-19,-474"/>
        </union>
        <union id="red-spawn-protection">
            <rectangle min="-29,-199" max="-2,-251"/>
            <rectangle min="-20,-250" max="-11,-265"/>
        </union>
    </union>
    <union id="wool-rooms">
        <union id="blue-wool-rooms"> <!-- red capture, blue defend -->
            <union id="yellow-wool-room">
                <cuboid min="-74,0,-499" max="-73,${right-wool-rooms-height},-502"/>
                <cuboid min="-75,0,-496" max="-74,${right-wool-rooms-height},-502"/>
                <cuboid min="-76,0,-494" max="-75,${right-wool-rooms-height},-503"/>
                <cuboid min="-77,0,-492" max="-76,${right-wool-rooms-height},-503"/>
                <cuboid min="-78,0,-491" max="-77,${right-wool-rooms-height},-503"/>
                <cuboid min="-79,0,-490" max="-78,${right-wool-rooms-height},-504"/>
                <cuboid min="-80,0,-489" max="-79,${right-wool-rooms-height},-504"/>
                <cuboid min="-81,0,-488" max="-80,${right-wool-rooms-height},-504"/>
                <cuboid min="-81,0,-487" max="-99,${right-wool-rooms-height},-505"/>
                <cuboid min="-82,0,-486" max="-98,${right-wool-rooms-height},-487"/>
                <cuboid min="-83,0,-485" max="-98,${right-wool-rooms-height},-486"/>
                <cuboid min="-84,0,-484" max="-98,${right-wool-rooms-height},-485"/>
                <cuboid min="-85,0,-483" max="-97,${right-wool-rooms-height},-484"/>
                <cuboid min="-86,0,-482" max="-97,${right-wool-rooms-height},-483"/>
                <cuboid min="-88,0,-481" max="-97,${right-wool-rooms-height},-482"/>
                <cuboid min="-90,0,-480" max="-96,${right-wool-rooms-height},-481"/>
                <cuboid min="-93,0,-479" max="-96,${right-wool-rooms-height},-480"/>
            </union>
            <cuboid id="orange-wool-room" min="54,0,-536" max="74,${left-wool-rooms-height},-517"/>
        </union>
        <union id="red-wool-rooms"> <!-- blue capture, red defend -->
            <union id="pink-wool-room">
                <cuboid min="44,0,-240" max="43,${right-wool-rooms-height},-237"/>
                <cuboid min="45,0,-243" max="44,${right-wool-rooms-height},-237"/>
                <cuboid min="46,0,-245" max="45,${right-wool-rooms-height},-236"/>
                <cuboid min="47,0,-247" max="46,${right-wool-rooms-height},-236"/>
                <cuboid min="48,0,-248" max="47,${right-wool-rooms-height},-236"/>
                <cuboid min="49,0,-249" max="48,${right-wool-rooms-height},-235"/>
                <cuboid min="50,0,-250" max="49,${right-wool-rooms-height},-235"/>
                <cuboid min="51,0,-251" max="50,${right-wool-rooms-height},-235"/>
                <cuboid min="51,0,-252" max="69,${right-wool-rooms-height},-234"/>
                <cuboid min="52,0,-253" max="68,${right-wool-rooms-height},-252"/>
                <cuboid min="53,0,-254" max="68,${right-wool-rooms-height},-253"/>
                <cuboid min="54,0,-255" max="68,${right-wool-rooms-height},-254"/>
                <cuboid min="55,0,-256" max="67,${right-wool-rooms-height},-255"/>
                <cuboid min="56,0,-257" max="67,${right-wool-rooms-height},-256"/>
                <cuboid min="58,0,-258" max="67,${right-wool-rooms-height},-257"/>
                <cuboid min="60,0,-259" max="66,${right-wool-rooms-height},-258"/>
                <cuboid min="63,0,-260" max="66,${right-wool-rooms-height},-259"/>
            </union>
            <cuboid id="purple-wool-room" min="-84,0,-203" max="-104,${left-wool-rooms-height},-222"/>
        </union>
    </union>
    <negative id="restricted-void-area">
        <union> <!-- buildable void area -->
            <!-- blue side right -->
            <rectangle min="-22,-473" max="-63,-410"/>
            <rectangle min="-49,-473" max="-67,-455"/>
            <!-- blue side left -->
            <rectangle min="33,-474" max="-2,-404"/>
            <complement>
                <rectangle min="3,-473" max="26,-496"/>
                <half origin="3,0,-473" normal="-1,0,-1"/>
            </complement>
            <rectangle min="45,-500" max="24,-486"/>
            <rectangle min="44,-486" max="24,-480"/>
            <!-- middle lane -->
            <rectangle min="17,-355" max="33,-384"/>
            <rectangle min="-47,-384" max="-63,-355"/>
            <!-- red side right -->
            <rectangle min="-8,-266" max="33,-329"/>
            <rectangle min="19,-266" max="37,-284"/>
            <!-- red side left -->
            <rectangle min="-63,-265" max="-28,-335"/>
            <complement>
                <rectangle min="-33,-266" max="-56,-243"/>
                <half origin="-33,0,-266" normal="0.99,0,1"/>
            </complement>
            <rectangle min="-75,-239" max="-54,-253"/>
            <rectangle min="-74,-253" max="-54,-259"/>
        </union>
    </negative>
    <apply use="deny(decoration)" region="spawn-protections"/>
    <apply enter="blue-team" region="blue-spawn-protection" message="You may not enter the enemy team's spawn!"/>
    <apply enter="red-team" region="red-spawn-protection" message="You may not enter the enemy team's spawn!"/>
    <apply enter="blue-team" region="red-wool-rooms" message="You may not enter your team's own wool rooms!"/>
    <apply enter="red-team" region="blue-wool-rooms" message="You may not enter your team's own wool rooms!"/>
    <apply enter="pink-wool-captured" region="victory-monument-protection-pink" message="You may not obstruct the victory monument!"/>
    <apply enter="purple-wool-captured" region="victory-monument-protection-purple" message="You may not obstruct the victory monument!"/>
    <apply enter="yellow-wool-captured" region="victory-monument-protection-yellow" message="You may not obstruct the victory monument!"/>
    <apply enter="orange-wool-captured" region="victory-monument-protection-orange" message="You may not obstruct the victory monument!"/>
    <apply block-place="only-iron-renew" block-break="only-iron" region="spawn-protections" message="You may only break iron blocks in the spawn area!"/>
    <apply block="deny(not-water-cause-world)" region="wool-rooms"/>
    <apply block="deny(red-team)" use="deny(red-team)" region="red-wool-rooms" message="You may not modify your team's own wool rooms!"/>
    <apply block="deny(blue-team)" use="deny(blue-team)" region="blue-wool-rooms" message="You may not modify your team's own wool rooms!"/>
    <apply block="wool-rooms-blocks" region="wool-rooms" message="You may not break this block in the wool rooms!"/>
    <apply block="deny(void)" region="restricted-void-area" message="You may not modify the void area!"/>
    <apply block="deny(obsidian)" early-warning="true" message="You may not break this block!"/>
    <apply block-physics="all(deny(redstone),deny(iron-trapdoor))" region="wool-rooms"/>
</regions>
<wools craftable="false">
    <wool id="pink-wool" team="blue-team" color="pink" monument="victory-monument-pink" location="63,12.5,-242"/>
    <wool id="purple-wool" team="blue-team" color="purple" monument="victory-monument-purple" location="-98,16.5,-210"/>
    <wool id="yellow-wool" team="red-team" color="yellow" monument="victory-monument-yellow" location="-93,12.5,-497"/>
    <wool id="orange-wool" team="red-team" color="orange" monument="victory-monument-orange" location="68,16.5,-529"/>
</wools>
<spawners>
    <spawner spawn-region="yellow-wool-spawn" player-region="yellow-wool-room" delay="3s" max-entities="8">
        <item material="wool" amount="2" damage="4"/>
    </spawner>
    <spawner spawn-region="orange-wool-spawn" player-region="orange-wool-room" delay="3s" max-entities="8">
        <item material="wool" amount="2" damage="1"/>
    </spawner>
    <spawner spawn-region="purple-wool-spawn" player-region="purple-wool-room" delay="3s" max-entities="8">
        <item material="wool" amount="2" damage="10"/>
    </spawner>
    <spawner spawn-region="pink-wool-spawn" player-region="pink-wool-room" delay="3s" max-entities="8">
        <item material="wool" amount="2" damage="6"/>
    </spawner>
</spawners>
<renewables>
    <renewable region="spawn-protections" renew-filter="only-iron" rate="0.5" avoid-players="1"/>
</renewables>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>arrow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
    <item>brown mushroom</item>
    <item>string</item>
    <item>redstone</item>
</itemremove>
<itemkeep>
    <item>smooth brick</item>
    <item>glass</item>
    <item>water bucket</item>
    <item>bucket</item>
    <item>golden apple</item>
</itemkeep>
<block-drops>
    <rule>
        <filter>
            <material>smooth brick:3</material>
        </filter>
        <drops>
            <item chance="0" material="smooth brick" damage="3"/>
        </drops>
    </rule>
    <rule>
        <filter>
            <material>coal ore</material>
        </filter>
        <drops>
            <item material="coal"/>
        </drops>
    </rule>
</block-drops>
<item-mods>
    <rule>
        <match>
            <material>iron sword</material>
            <material>iron axe</material>
            <material>iron spade</material>
            <material>shears</material>
            <material>diamond chestplate</material>
        </match>
        <modify unbreakable="true"/>
    </rule>
    <rule>
        <match>
            <material>iron pickaxe</material>
        </match>
        <modify unbreakable="true" enchantment="efficiency"/>
    </rule>
</item-mods>
<kill-rewards>
    <kill-reward>
        <item material="smooth brick" amount="32" damage="3"/>
        <item material="glass" amount="8"/>
    </kill-reward>
</kill-rewards>
<gamerules>
    <doFireTick>false</doFireTick>
</gamerules>
<hunger>
    <depletion>off</depletion>
</hunger>
<maxbuildheight>27</maxbuildheight>
</map>
