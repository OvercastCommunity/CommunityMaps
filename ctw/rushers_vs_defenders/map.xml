<map proto="1.5.0">
<name>Rushers vs Defenders</name>
<version>1.1.1</version>
<objective>Capture your enemy's wool or defend yours!</objective>
<created>2026-03-22</created>
<gamemode>ad</gamemode>
<gamemode>ctw</gamemode>
<include id="gapple-kill-reward" />
<include id="water-lanes" />
<authors>
    <author uuid="f610e558-a3c8-44fb-8622-68cc49dbc18f" /> <!-- jcane -->
</authors>
<contributors>
    <contributor uuid="64e840c8-4fb5-4659-a36b-ff93e2f6113a" contribution="XML" /> <!-- Javg_ -->
</contributors>
<constants>
    <constant id="water-lane-timer">30m</constant>
</constants>
<teams>
    <team id="rushers" max="28" max-overfill="32" color="red">Rushers</team>
    <team id="defenders" max="28" max-overfill="32" color="blue">Defenders</team>
</teams>
<time result="defenders">45m</time>
<kits>
    <kit id="default-kit">
        <item slot="0" material="iron sword" unbreakable="true" />
        <item slot="1" material="bow" unbreakable="true" />
        <item slot="2" material="iron pickaxe" unbreakable="true" />
        <item slot="3" material="iron axe" unbreakable="true" />
        <item slot="4" material="log" amount="64" />
        <item slot="5" material="wool" team-color="true" amount="64" unbreakable="true" />
        <item slot="8" material="golden apple" />
        <item material="arrow" slot="28" amount="32" />
        <item material="iron spade" slot="30" unbreakable="true" />
        <helmet material="leather helmet" team-color="true" />
        <chestplate material="leather chestplate" team-color="true" />
        <leggings material="chainmail leggings" enchantment="projectile protection" />
        <boots material="leather boots" team-color="true" />
    </kit>
</kits>
<spawns>
    <default>
        <region>
            <point>-118.5,53,-12.5</point>
        </region>
    </default>
    <spawn team="rushers" kit="default-kit">
        <region yaw="90">
            <point>-17.5,21,-10.5</point>
        </region>
    </spawn>
    <spawn team="defenders" kit="default-kit">
        <region yaw="-90">
            <point>-206.5,26,-10.5</point>
        </region>
    </spawn>
</spawns>
<respawns>
    <respawn delay="0" filter="rushers" />
    <respawn delay="3s" filter="defenders" />
</respawns>
<filters>
    <not id="no-void">
        <void/>
    </not>
    <all id="renewable-iron-block">
        <material id="iron-block">iron block</material>
        <not><cause>player</cause></not>
    </all>
    <material id="wool">wool:10</material>
    <any id="wool-room-allowed">
        <material>web</material>
        <material>water</material>
        <material>stationary water</material>
        <material>wood</material>
        <material>wool</material>
        <material>log</material>
        <material>stained clay</material>
    </any>
    <material id="glass">stained glass:0</material>
</filters>
<regions>
    <union id="water-lanes">
        <cuboid min="-221,0,30" max="-237,1,13" />
        <cuboid min="-221,0,-34" max="-237,1,-51" />
        <cuboid min="-269,0,-34" max="-286,1,-19" />
        <cuboid min="-286,0,13" max="-269,1,-2" />
    </union>
    <rectangle id="rushers-spawn" min="-36,-37" max="-14,16" />
    <union id="defenders-spawn">
        <rectangle min="-167,15" max="-210,-36" />
        <cuboid min="-231,25,-18" max="-210,41,-3" />
    </union>
    <rectangle id="wool-room" min="-311,-1" max="-335,-20" />
    <union id="buildable-wool-room">
        <cuboid min="-317,34,-2" max="-334,39,-19" />
        <rectangle min="-311,-2" max="-319,-19" />
    </union>
    <complement id="not-buildable-wool-room">
        <region id="wool-room" />
        <region id="buildable-wool-room" />
    </complement>
    <apply block-break="never" block-place="wool" message="You may not obstruct the wool monument!">
        <region>
            <cuboid min="-52,17,-14" max="-45,26,-7" />
        </region>
    </apply>
    <apply region="rushers-spawn" block-break="iron-block" block-place="renewable-iron-block" message="You may not modify here!" />
    <apply region="rushers-spawn" enter="rushers" message="You may not enter here!" />
    <apply region="defenders-spawn" block-break="iron-block" block-place="renewable-iron-block" message="You may not modify here!" />
    <apply region="defenders-spawn" enter="defenders" message="You may not enter here!" />
    <apply region="wool-room" enter="rushers" message="You may not enter the wool room!" />
    <apply region="not-buildable-wool-room" block="never" message="You may not modify the wool room!" />
    <apply region="buildable-wool-room" block-break="wool-room-allowed" block-place="wool-room-allowed" message="You may not modify the wool room!" />
    <apply block="no-void" message="You may not modify the void area!">
        <region>
            <rectangle id="main-area" min="-15,-83" max="-334,62" />
        </region>
    </apply>
</regions>
<actions>
    <trigger scope="match" filter="match-started">
        <action>
            <fill filter="glass" material="piston moving piece">
                <cuboid min="-15,0,-83" max="-334,1,62" />
            </fill>
        </action>
    </trigger>
</actions>
<wools>
    <wool id="purple-wool" team="rushers" color="purple" location="-330,19,-10.5">
        <monument>
            <block>-48.5,19.5,-10.5</block>
        </monument>
    </wool>
</wools>
<renewables>
    <renewable avoid-players="4" renew-filter="iron-block" />
</renewables>
<spawners>
    <spawner player-region="wool-room" max-entities="3" delay="3s" filter="rushers">
        <spawn-region>
            <point>-330,19,-10.5</point>
        </spawn-region>
        <item material="wool" damage="10" />
    </spawner>
</spawners>
<kill-rewards>
    <kill-reward>
        <item material="arrow" amount="12" />
    </kill-reward>
</kill-rewards>
<maxbuildheight>38</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
    <tool>shears</tool>
</toolrepair>
<itemremove>
    <item>sapling</item>
    <item>smooth brick</item>
    <item>step:0</item>
    <item>redstone wire</item>
    <item>string</item>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
    <item>gravel</item>
    <item>flint</item>
</itemremove>
</map>