<map proto="1.5.0">
<name>Sunbliss</name>
<version>1.0.5</version>
<objective>Capture the enemy team's wool!</objective>
<created>2026-01-10</created>
<phase>staging</phase>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="1af9f952-e33e-42a5-8e1e-296757747fdc" contribution="Map Author, Base XML Creator"/> <!-- Alphaboy98yt -->
</authors>
<contributors>
    <contributor uuid="3a9ef640-68e3-4202-b5bc-ab648b64a40e" contribution="Contributed Initial XML Completion"/> <!-- iCompass -->
    <contributor uuid="84d0f14a-1aae-447f-838c-8ac742667d67" contribution="XML Remake and Assistance"/> <!-- limefox3054 -->
</contributors>
<teams>
    <team id="blue-team" color="blue" max="20">Blue</team>
    <team id="red-team" color="dark red" max="20">Red</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true" enchantment="infinity"/>
        <item slot="2" material="iron pickaxe" unbreakable="true"/>
        <item slot="3" material="iron axe" unbreakable="true"/>
        <item slot="4" material="wood" amount="64"/>
        <item slot="5" material="glass" amount="32"/>
        <item slot="8" material="golden apple"/>
        <item slot="28" material="arrow"/>
        <item slot="30" material="iron spade" unbreakable="true"/>
        <item slot="31" material="wood" amount="64"/>
        <helmet material="leather helmet" unbreakable="true" team-color="true"/>
        <chestplate material="leather chestplate" unbreakable="true" team-color="true"/>
        <leggings material="chainmail leggings" unbreakable="true" enchantment="protection projectile:2"/>
        <boots material="leather boots" unbreakable="true" team-color="true"/>
        <effect duration="5s" amplifier="5">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <spawn team="blue-team" kit="spawn-kit" yaw="44.5" region="blue-spawn-point"/>
    <spawn team="red-team" kit="spawn-kit" yaw="-135.5" region="red-spawn-point"/>
    <default yaw="90" region="obs-spawn-point"/>
</spawns>
<filters>
    <!-- used with deny inline filters to prevent block destruction caused by water flow -->
    <all id="not-water-cause-world">
        <not>
            <any>
                <material>water</material>
                <material>stationary water</material>
            </any>
        </not>
        <cause>world</cause>
    </all>
    <all id="wool-rooms-blocks">
        <blocks region="wool-rooms">
            <any> <!-- breakable blocks -->
                <material>air</material>
                <material>web</material>
                <material>redstone wire</material>
            </any>
        </blocks>
        <not> <!-- non-placeable blocks -->
            <void/>
        </not>
    </all>
    <all id="only-iron-renew">
        <material id="only-iron">iron block</material>
        <cause>world</cause>
    </all>
    <any id="over-void-material"> <!-- non-breakable blocks -->
        <material>web</material>
        <material>stained glass:8</material>
        <material>stained glass pane:11</material>
        <material>stained glass pane:14</material>
    </any>
    <any id="wool-room-decoration">
        <any id="spawn-decoration">
            <material>lever</material>
            <material>stone button</material>
            <material>wood button</material>
            <material>trap door</material>
        </any>
        <material>iron trapdoor</material>
        <material>cauldron</material>
        <!-- added to prevent sound spam -->
        <material>wooden door</material>
        <material>spruce door</material>
        <material>birch door</material>
        <material>jungle door</material>
        <material>dark oak door</material>
        <material>fence gate</material>
        <material>spruce fence gate</material>
        <material>birch fence gate</material>
        <material>jungle fence gate</material>
    </any>
    <material id="sign">wall sign</material>
    <material id="redstone">redstone wire</material>
</filters>
<regions>
    <!-- team spawn points -->
    <point id="blue-spawn-point">208.5,9,51.5</point>
    <point id="red-spawn-point">113.5,9,271.5</point>
    <cylinder id="obs-spawn-point" base="161.5,68,161.5" radius="0.75" height="0"/>
    <!-- victory monuments -->
    <block id="victory-monument-red-wool">214,10,51</block>
    <block id="victory-monument-blue-wool">107,10,271</block>
    <union id="victory-monument-protections">
        <cuboid min="215,9,50" max="213,20,53"/>
        <cuboid min="107,9,273" max="109,20,270"/>
    </union>
    <union id="spawn-protections">
        <union id="blue-spawn-protection">
            <rectangle min="193,63" max="218,44"/>
            <rectangle min="193,65" max="208,63"/>
            <rectangle min="192,67" max="207,65"/>
            <rectangle min="191,69" max="206,67"/>
            <rectangle min="190,71" max="205,69"/>
            <rectangle min="189,73" max="204,71"/>
            <rectangle min="188,74" max="203,73"/>
        </union>
        <union id="red-spawn-protection">
            <rectangle min="129,260" max="104,279"/>
            <rectangle min="129,258" max="114,260"/>
            <rectangle min="130,256" max="115,258"/>
            <rectangle min="131,254" max="116,256"/>
            <rectangle min="132,252" max="117,254"/>
            <rectangle min="133,250" max="118,252"/>
            <rectangle min="134,249" max="119,250"/>
        </union>
    </union>
    <union id="wool-rooms">
        <union id="blue-wool-room"> <!-- red capture, blue defend -->
            <cuboid min="174,0,38" max="148,62,35"/>
            <cuboid min="175,0,35" max="147,62,21"/>
            <cuboid min="174,0,21" max="163,62,20"/>
            <cuboid min="158,0,21" max="148,62,20"/>
            <cuboid min="171,0,20" max="166,62,19"/>
            <cuboid min="155,0,20" max="150,62,19"/>
        </union>
        <union id="red-wool-room"> <!-- blue capture, red defend -->
            <cuboid min="148,0,285" max="174,62,288"/>
            <cuboid min="147,0,288" max="175,62,302"/>
            <cuboid min="148,0,302" max="159,62,303"/>
            <cuboid min="164,0,302" max="174,62,303"/>
            <cuboid min="151,0,303" max="156,62,304"/>
            <cuboid min="167,0,303" max="172,62,304"/>
        </union>
    </union>
    <complement id="wool-rooms-without-doors"> <!-- wool rooms excluding doors in actual use -->
        <region id="wool-rooms"/>
        <cuboid min="167,18,28" max="166,20,29"/>
        <cuboid min="155,18,295" max="156,20,294"/>
    </complement>
    <negative id="restricted-void-area">
        <union> <!-- buildable void area -->
            <complement> <!-- blue side diagonal island -->
                <rectangle min="129,85" max="152,62"/>
                <half origin="129,0,85" normal="-1,0,-1"/>
            </complement>
            <!-- middle lane -->
            <rectangle min="197,146" max="181,177"/>
            <rectangle min="125,177" max="141,146"/>
            <complement> <!-- red side diagonal island -->
                <rectangle min="193,238" max="170,261"/>
                <half origin="193,0,238" normal="1,0,1"/>
            </complement>
        </union>
    </negative>
    <apply use="deny(spawn-decoration)" region="spawn-protections"/>
    <apply enter="blue-team" region="blue-spawn-protection" message="You may not enter the enemy team's spawn!"/>
    <apply enter="red-team" region="red-spawn-protection" message="You may not enter the enemy team's spawn!"/>
    <apply enter="blue-team" region="red-wool-room" message="You may not enter your team's own wool room!"/>
    <apply enter="red-team" region="blue-wool-room" message="You may not enter your team's own wool room!"/>
    <apply enter="never" block="never" region="victory-monument-protections" message="You may not obstruct the victory monument!"/>
    <apply block-place="only-iron-renew" block-break="any(only-iron,sign)" region="spawn-protections" message="You may only break iron blocks in the spawn area!"/>
    <apply block="deny(not-water-cause-world)" region="wool-rooms"/>
    <apply block="deny(red-team)" use="deny(red-team)" region="red-wool-room" message="You may not modify your team's own wool room!"/>
    <apply block="deny(blue-team)" use="deny(blue-team)" region="blue-wool-room" message="You may not modify your team's own wool room!"/>
    <apply block="wool-rooms-blocks" region="wool-rooms" message="You may not break this block in the wool room!"/>
    <apply block-place="deny(void)" region="restricted-void-area" message="You may not build in the void area!"/>
    <apply block-break="deny(all(void,over-void-material))" region="restricted-void-area" message="You may not break this block in the void area!"/>
    <apply block-physics="all(deny(redstone),deny(wool-room-decoration))" use="deny(wool-room-decoration)" region="wool-rooms-without-doors"/>
</regions>
<wools craftable="false">
    <wool team="blue-team" color="red" monument="victory-monument-red-wool" location="149.5,19,296"/>
    <wool team="red-team" color="blue" monument="victory-monument-blue-wool" location="172.5,19,27"/>
</wools>
<renewables>
    <renewable region="spawn-protections" renew-filter="only-iron"/>
</renewables>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
    <tool>arrow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
    <item>string</item>
    <item>redstone</item>
    <item>red rose</item>
    <item>brown mushroom</item>
    <item>sapling</item>
    <item>apple</item>
    <item>long grass</item>
    <item>seeds</item>
</itemremove>
<itemkeep>
    <item>wood:0</item>
    <item>glass</item>
    <item>golden apple</item>
</itemkeep>
<block-drops>
    <rule>
        <filter>
            <material>coal ore</material>
        </filter>
        <drops>
            <item material="coal"/>
        </drops>
    </rule>
</block-drops>
<kill-rewards>
    <kill-reward>
        <item material="wood" amount="16"/>
        <item material="glass" amount="8"/>
    </kill-reward>
</kill-rewards>
<gamerules>
    <!-- Temporary workaround to prevent leaf decay. The map file itself must be updated to resolve the root cause -->
    <randomTickSpeed>0</randomTickSpeed>
</gamerules>
<hunger>
    <depletion>off</depletion>
</hunger>
<maxbuildheight>24</maxbuildheight>
</map>
