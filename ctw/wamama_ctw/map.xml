<!--about the regions section... IT WORKS IT WORKS SO DW. saying it cuz i dont remember waht iu did but it works heh-->
<map proto="1.5.0">
<authors>
	<author uuid="9c14b7e9-8488-427a-bc81-7193becde2d3" contribution="Map and XML"/> <!--TinyPigMX-->
</authors>
<name>Wamama CTW</name>
<created>2025-08-11</created>
<gamemode>CTW</gamemode>
<version>1.0.0</version>
<phase>staging</phase>
<objective>You have to capture the wool on the enemy side and place it on your victory monument!</objective> <!--lol whwat nsd-->
<teams>
	<team id="red-team" color="dark red" max="24">Red</team>
	<team id="blue-team" color="blue" max="24">Blue</team>
</teams>
<!--SPAWNS SPAWNS!!-->
<spawns>
	<spawn team="red-team" kit="spawn-kit">
		<region>
			<point>92.5,15.5,-184.5</point>
		</region>
	</spawn>
	<spawn team="blue-team" kit="spawn-kit" yaw="180">
		<region>
			<point>-73.5,15.5,84.5</point>
		</region>
	</spawn>
	<default yaw="90">
		<region>
			<point>9.5,54.5,-49.5</point>
		</region>
	</default>
</spawns>
<!--KITS!! simple, really simple.-->
<kits>
	<kit id="spawn-kit">
		<effect duration="5s" amplifier="10">instant health</effect>
		<item slot="0" material="iron sword" unbreakable="true"/>
		<item slot="1" material="bow" unbreakable="true"/>
		<item slot="28" material="arrow" amount="32"/>
		<item slot="2" material="iron axe" unbreakable="true">
			<enchantment level="2">efficiency</enchantment>
		</item>
		<item slot="3" material="iron pickaxe" unbreakable="true">
			<enchantment level="2">efficiency</enchantment>
		</item>
		<item slot="30" material="iron spade" unbreakable="true">
			<enchantment level="3">efficiency</enchantment>
		</item>
		<item slot="5" material="log 2" damage="1" amount="32"/>
		<item slot="6" material="stained clay" team-color="true" amount="64"/>
		<item slot="33" material="glass" amount="32"/>
		<item slot="7" material="bucket"/>
		<item slot="8" material="golden apple"/>
	<!--armor-->
		<helmet material="leather helmet" team-color="true" unbreakable="true"/>
		<chestplate material="leather chestplate" team-color="true" unbreakable="true"/>
		<leggings material="chainmail leggings" unbreakable="true">
			<enchantment level="2">projectile protection</enchantment>
		</leggings>
		<boots material="iron boots" unbreakable="true"/>
	</kit>
</kits>
<!--F**k filters, am i right. haha no, am i the only one taht thinks theyure boring??-->
<filters>
<all id="wool-room-blocks"> <!--so they cant break chests in wool room-->
	<blocks region="wool-rooms">
		<not>
			<material>chest</material>
		</not>
	</blocks>
</all>
<all id="iron-renew"> <!--classic iron renew-->
	<material id="only-iron-blocks">iron block</material>
	<cause>world</cause>
</all>
</filters>
<!--regions, this time i did them first!!!-->
<regions>
	<!--im gonna try using mirror, leaving a note if i do it!!-->
	<mirror id="game-zone2" region="game-zone" origin="9.5,0,-50" normal="1,0,0"/>
	<!--WHY, WHY DID ITHINK MIRROR WOULD WORK. UUUGGH-->
	<negative id="void-zone">
		<union id="game-zone"> <!--names below dont matter cuz they wont be used-->
			<rectangle id="spawnthing" min="-52.5,94.5" max="-82.5,-74.5"/> <!--like, so if i mak a mistake on the coords, i know wha tit is-->
			<rectangle id="gianttree" min="-82.5,-75.5" max="-42.5, -115.5"/>
			<rectangle id="cityandhut" min="-51.5,15.5" max="60.5,-14.5"/>
			<rectangle id="woolpath" min="-83.5,10.5" max="-151.5,-9.5"/>
			<region id="wool-rooms"/>
		</union>
		<mirror region="game-zone2" origin="9.5,0,-50" normal="0,0,1"/> 
	</negative>
	<!--HOCHIMAMA, A GAMBLE???? I LIKE A GOOD GAMBLE-->
	<mirror id="mirroredforcyan" region="purple-wool-room" origin="9.5,0,-50" normal="1,0,0"/>
	<union id="wool-rooms">
		<cuboid id="purple-wool-room" min="-172.5,0,15.5" max="-152.5,36,-14.5"/>
		<mirror id="cyan-wool-room" region="mirroredforcyan" origin="9.5,0,-50" normal="0,0,1"/>
	</union>
	<!--hheheh ehMUWAHDBD MI HIM HUWHUI, what is this for??? so they dont get inside their OWN WOOL ROOM-->
	<mirror id="mirroredfor-theotherteam" region="dopdopyesyes" origin="9.5,0,-50" normal="1,0,0"/>
	<union id="dopdopyesyes">
		<union id="purplewool"> <!--this is uuh, when u see wool rooms they could walk around it, ANY team, so uuh, i made it so they couldnt-->
			<cuboid min="-151.5,0,15.5" max="-151.5,36,15.5"/> 
			<cuboid min="-151.5,0,-14.5" max="-151.5,36,-14.5"/>
		</union>
	</union>
	<mirror id="cyanwool" region="mirroredfor-theotherteam" origin="9.5,0,-50" normal="0,0,1"/>
	<!--yheadnmamaaaoooh, spawns-->
	<mirror id="mirroredfor-redspawn" region="blue-spawn-area" origin="9.5,0,-50" normal="1,0,0"/>
	<union id="spawn-areas">
		<cuboid id="blue-spawn-area" min="-52.5,0,95.2" max="-82.5,50,60.8"/> <!--the 0.2 doesnt work but im too lazy to change it (DOESNT MATTER)-->
		<mirror id="red-spawn-area" region="mirroredfor-redspawn" origin="9.5,0,-50" normal="0,0,1"/>
	</union>
		<!--separation (apply, actually)...-->
	<apply enter="deny(red-team)" region="blue-spawn-area" message="You may not enter the enemy spawn!"/>
	<apply enter="deny(blue-team)" region="red-spawn-area" message="You may not enter the enemy spawn!"/>
<!--below is so spawn cant be modified (like, only for iron, by iron) and wool-->
	<apply block-break="only-iron-blocks" block-place="iron-renew" region="spawn-areas" message="You may not edit the spawn areas!"/>
	<apply block="deny(red-team)" region="cyan-wool-room" message="You may not edit your own wool room!"/>
	<apply block="deny(blue-team)" region="purple-wool-room" message="You may not edit your own wool room!"/>
<!--applying stuff-->
	<apply region="void-zone" block="never" message="You may not edit the void area!"/>
	<apply region="purple-wool-room" enter="deny(blue-team)" message="You may not enter your team's wool room!"/>
	<apply region="cyan-wool-room" enter="deny(red-team)" message="You may not enter your team's wool room!"/>
	<apply block="wool-room-blocks" region="wool-rooms" message="You may not break any wool room chests!"/>
	<apply enter="deny(blue-team)" region="purplewool" message="You may not enter your team's wool room!"/>
	<apply enter="deny(red-team)" region="cyanwool" message="You may not enter your team's wool room!"/>
<!--MIrror did work, but it still sucks, think i get how it works now tho-->
</regions>
<!--WOOL monument??? really simple stuff left in here-->	
<wools>
	<wool team="red-team" color="purple" location="-156.5,14,0.5">
		<monument>
			<block>87,16,-183</block>
		</monument>
	</wool>
	<wool team="blue-team" color="cyan" location="175.5,14,-100.5">
		<monument>
			<block>-69,16,82</block>
		</monument>
	</wool>
</wools>
<renewables>
	<renewable region="spawn-areas" renew-filter="only-iron-blocks" avoid-players="1"/>
</renewables>
<kill-rewards>
	<kill-reward>
		<item amount="16">glass</item>
		<item amount="16" damage="1">log 2</item>
		<item amount="16" team-color="true">stained clay</item>
		<item>golden apple</item>
		<item amount="16">arrow</item>
	</kill-reward>
</kill-rewards>
<toolrepair>
	<tool>iron sword</tool>
	<tool>iron pickaxe</tool>
	<tool>iron axe</tool>
	<tool>bow</tool>
	<tool>iron spade</tool>
</toolrepair>
<itemremove>
	<item>leather helmet</item>
	<item>leather chestplate</item>
	<item>chainmail leggings</item>
	<item>iron boots</item>
	<item>clay ball</item>
</itemremove>
<maxbuildheight>33</maxbuildheight>
<hunger>
	<depletion>off</depletion>
</hunger>
<!--why are there so many notes?? cuz, well, maybe to help understand??-->
</map>