<map proto="1.5.0">
<name>Chess Cathedral</name>
<version>1.0.8</version>
<created>2026-05-10</created>
<constants>
    <constant id="team-flag-posts">true</constant>
    <constant id="team-size">11</constant>
    <constant id="team-one-name">Blue</constant>
    <constant id="team-two-name">Red</constant>
    <constant id="team-one-color">blue</constant>
    <constant id="team-two-color">red</constant>
    <constant id="team-one-spawn">0.5,13,-57.5</constant>
    <constant id="team-one-yaw">0</constant>
    <constant id="team-two-spawn">0.5,13,58.5</constant>
    <constant id="team-two-yaw">180</constant>
    <constant id="flag-post">0.5,5,0.5</constant>
    <constant id="team-one-flag-post">0.5,2,-37.5</constant> <!-- Where flag respawns after a score -->
    <constant id="team-two-flag-post">0.5,2,38.5</constant>
    <constant id="void-plane">-1</constant>
    <constant id="time-limit">12m</constant>
    <constant id="flag-respawn">7s</constant>
    <constant id="flag-prerespawn">6.8s</constant>
    <constant id="instaheal-default">2</constant>
</constants>
<include id="touchdown"/>
<authors>
    <author uuid="f610e558-a3c8-44fb-8622-68cc49dbc18f"/> <!-- jcane -->
</authors>
<contributors>
    <contributor uuid="c31e94b2-7678-4551-847e-989c1423323a" contribution="Tom Brady Author"/> <!-- TommyHillfigger -->
    <contributor uuid="b390b87a-47e8-40d8-968a-9e7e2582a88b" contribution="Tom Brady Author"/> <!-- MewTwoKing -->
    <contributor uuid="2fd57dff-4cff-4b60-96a4-d26e37759c03" contribution="Tom Brady XML"/> <!-- Furrie -->
    <contributor uuid="9d4779a8-d35f-45d2-b51c-95de7a77e128" contribution="Bridge Snippets"/> <!-- zzuf -->
    <contributor uuid="c25a6f7b-4c42-40da-8cd6-add53f0c84eb" contribution="Tom Brady XML/Updates"/> <!-- arcadeboss -->
    <contributor uuid="e419983c-bb20-438d-b900-717f131a272f" contribution="XML Message Names"/> <!-- KuNet -->
    <contributor uuid="aa6a6b35-db22-4cff-bfce-3093cf4cf2e6" contribution="XML Updates"/> <!-- honeyfuggle -->
</contributors>
<spawns>
    <default>
        <regions>
            <point yaw="-90">-43.5,11,0.5</point>
        </regions>
    </default>
</spawns>
<filters>
    <below id="team-one-4s" z="-21.5"/>
    <below id="team-one-3s" z="0.5"/>
    <above id="team-two-4s" z="22.5"/>
    <above id="team-two-3s" z="0.5"/>
</filters>
<regions>
    <cuboid id="playing-field" min="-32,1,-55" max="33,10,56"/>
    <cuboid id="team-one-portal" min="-32,1,-55" max="33,10,-43"/> <!-- Red scores -->
    <cuboid id="team-two-portal" min="33,1,56" max="-32,10,44"/> <!-- Blue scores -->
</regions>
<respawns auto="true">
    <respawn filter="all(team-one-4s,team-one,game_state=${carry})" delay="4s"/>
    <respawn filter="all(team-one-3s,team-one,game_state=${carry})" delay="3.5s"/>
    <respawn filter="all(team-two-4s,team-two,game_state=${carry})" delay="4s"/>
    <respawn filter="all(team-two-3s,team-two,game_state=${carry})" delay="3.5s"/>
    <respawn delay="3s"/>
</respawns>
</map>