        <regions>
            <point>2,19,123</point>
        </regions>
    </default>
    <spawn team="team-1" region="team-1-spawn" kit="spawn-kit" filter="score-0"/>
    <spawn team="team-2" region="team-2-spawn" kit="spawn-kit" filter="score-0"/>
    <spawn team="team-3" region="team-3-spawn" kit="spawn-kit" filter="score-0"/>
    <spawn team="team-4" region="team-4-spawn" kit="spawn-kit" filter="score-0"/>
    <spawn team="team-5" region="team-5-spawn" kit="spawn-kit" filter="score-0"/>
    <spawn team="team-6" region="team-6-spawn" kit="spawn-kit" filter="score-0"/>
    <spawn team="team-1" region="team-1-checkpoint-1" kit="spawn-kit" filter="score-1"/>
    <spawn team="team-2" region="team-2-checkpoint-1" kit="spawn-kit" filter="score-1"/>
