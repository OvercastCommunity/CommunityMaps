                <all>
                    <attacker>
                        <team>team-2</team>
                    </attacker>
                    <victim>
                        <team>team-2</team>
                    </victim>
                </all>
                <all>
                    <attacker>
                        <team>team-3</team>
                    </attacker>
                    <victim>
                        <team>team-3</team>
                    </victim>
                </all>
                <all>
                    <attacker>
                        <team>team-4</team>
