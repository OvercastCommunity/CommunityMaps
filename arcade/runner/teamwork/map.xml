<filters>
    <deny id="deny-use">
        <any>
            <material>dispenser</material>
            <material>trap door</material>
        </any>
    </deny>
    <any id="any-lava">
        <material>lava</material>
        <material>stationary lava</material>
    </any>
    <any id="obstacle-1-apply-death">
        <all>
            <team>team-1</team>
            <offset id="team-1-obstacle-1-lava-activated" vector="-18,12,23" filter="any-lava"/>
        </all>
        <all>
            <team>team-2</team>
            <offset id="team-2-obstacle-1-lava-activated" vector="-39,12,23" filter="any-lava"/>
        </all>
        <all>
            <team>team-3</team>
            <offset id="team-3-obstacle-1-lava-activated" vector="-60,12,23" filter="any-lava"/>
        </all>
        <all>
            <team>team-4</team>
            <offset id="team-4-obstacle-1-lava-activated" vector="-81,12,23" filter="any-lava"/>
        </all>
        <all>
            <team>team-5</team>
            <offset id="team-5-obstacle-1-lava-activated" vector="-102,12,23" filter="any-lava"/>
        </all>
        <all>
            <team>team-6</team>
            <offset id="team-6-obstacle-1-lava-activated" vector="-123,12,23" filter="any-lava"/>
        </all>
    </any>
    <any id="obstacle-3-breakable">
        <material>obsidian</material>
        <material>ender stone</material>
    </any>
    <material id="only-stained-glass">stained glass</material>
    <score id="score-0">0</score>
    <score id="score-1">1</score>
    <score id="score-2">2</score>
    <after id="after-10s" message="Spawn cages will open in {0}" duration="10s">
        <match-started/>
    </after>
</filters>
<score>
    <limit>3</limit>
    <box points="1" region="checkpoint-1" filter="score-0"/>
    <box points="1" region="checkpoint-2" filter="score-1"/>
</score>
<wools color="white" craftable="true" show-sidebar="false" location="0,0,0">
    <wool team="team-1" monument="team-1-wool-monument"/>
    <wool team="team-2" monument="team-2-wool-monument"/>
    <wool team="team-3" monument="team-3-wool-monument"/>
    <wool team="team-4" monument="team-4-wool-monument"/>
    <wool team="team-5" monument="team-5-wool-monument"/>
    <wool team="team-6" monument="team-6-wool-monument"/>
</wools>
<actions>
