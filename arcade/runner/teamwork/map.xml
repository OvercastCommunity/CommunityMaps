                    <victim>
                        <team>team-4</team>
                    </victim>
                </all>
                <all>
                    <attacker>
                        <team>team-5</team>
                    </attacker>
                    <victim>
                        <team>team-5</team>
                    </victim>
                </all>
                <all>
                    <attacker>
