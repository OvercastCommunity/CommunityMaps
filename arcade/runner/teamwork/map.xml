<teams> <!-- Minimum 3 players needed to pass some obstacles -->
    <team id="team-1" color="dark red" min="3" max="8">Red</team>
    <team id="team-2" color="blue" min="3" max="8">Blue</team>
    <team id="team-3" color="green" min="3" max="8">Green</team>
    <team id="team-4" color="yellow" min="3" max="8">Yellow</team>
    <team id="team-5" color="gold" min="3" max="8">Orange</team>
    <team id="team-6" color="light purple" min="3" max="8">Pink</team>
</teams>
<kits>
    <kit id="nv-kit">
        <effect>night vision</effect>
    </kit>
    <kit id="spawn-kit" parents="nv-kit">
        <helmet material="leather helmet" team-color="true" locked="true" unbreakable="true"/>
    </kit>
    <kit id="lava-death-kit" force="true">
        <health>1</health>
    </kit>
    <kit id="obstacle-2-start-kit" force="true">
        <effect duration="0s">jump boost</effect>
        <action>
            <replace-item ignore-metadata="true">
                <find material="potion"/>
                <replace material="air"/>
            </replace-item>
        </action>
    </kit>
</kits>
<spawns>
