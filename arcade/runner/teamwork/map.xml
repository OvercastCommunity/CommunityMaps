    <trigger filter="after-10s" action="open-spawn-cages" scope="match"/>
</actions>
<lootables>
    <loot id="obstacle-1-potion">
        <item material="potion" damage="11">
            <effect duration="1m">jump boost</effect>
        </item>
    </loot>
    <loot id="obstacle-3-stick">
        <item material="stick" amount="2"/>
    </loot>
    <loot id="obstacle-3-diamond">
        <item material="diamond"/>
    </loot>
    <fill loot="obstacle-1-potion" filter="obstacle-1-lootable" refill-interval="30s"/>
    <fill loot="obstacle-3-stick" filter="obstacle-3-stick-chests" refill-interval="60s"/>
    <fill loot="obstacle-3-diamond" filter="obstacle-3-diamond-chests" refill-interval="60s"/>
</lootables>
<spawners>
